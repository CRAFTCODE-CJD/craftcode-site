---
/**
 * Boosty subscription card for the home page.
 *
 * Boosty is a paywalled content platform — subscribers get local access
 * to project files, tutorials, and early builds. The card explains
 * WHAT a subscription unlocks, not "how to use Boosty" (its a storefront,
 * not documentation). Keep copy concrete: what kinds of files/projects
 * are behind the paywall.
 */
interface Props {
  url?: string;
  /** Short list of what subscribers get — update as content ships. */
  perks?: string[];
}

const {
  url = 'https://boosty.to/channel-jonathan-developer',
  perks = [
    'Исходники к туториалам YouTube',
    'Бета-доступ к будущим плагинам',
    'Проекты-песочницы для экспериментов',
  ],
} = Astro.props;
---

<section class="bst-card" aria-label="Boosty">
  <div class="bst-left">
    <span class="bst-mark" aria-hidden="true">
      <span class="bst-mark-b">B</span>
    </span>
    <span class="ds-label">// boosty · подписка</span>
    <h3 class="bst-heading">
      Для тех кто хочет <span class="accent">разобрать</span><br/>
      каждый плагин изнутри
    </h3>
    <p class="bst-pitch">
      На Boosty выкладываю исходники туториалов, проекты-песочницы и
      ранний доступ к плагинам до релиза на FAB. Локальный контент —
      подписчики скачивают и работают с файлами у себя.
    </p>
    <div class="bst-actions">
      <a class="btn primary" href={url} target="_blank" rel="noopener">
        Открыть Boosty ↗
      </a>
    </div>
  </div>

  <ul class="bst-perks" aria-label="Что включает подписка">
    {perks.map((p) => (
      <li><span class="bst-perk-marker">+</span> {p}</li>
    ))}
  </ul>
</section>

<style>
  .bst-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 28px;
    align-items: start;
    padding: 20px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid #f15f2c;    /* Boosty orange */
    border-radius: 4px;
    margin: 22px 0;
    position: relative;
    overflow: hidden;
  }
  /* Subtle diagonal-stripe glow to hint at "premium" without feeling cheap */
  .bst-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        45deg,
        transparent 0 32px,
        color-mix(in oklab, #f15f2c 4%, transparent) 32px 33px
      );
    pointer-events: none;
  }

  .bst-left {
    position: relative;
    display: grid;
    gap: 10px;
    align-content: start;
  }
  .bst-mark {
    display: inline-grid;
    place-items: center;
    width: 36px; height: 36px;
    border-radius: 8px;
    background: #f15f2c;
    color: #fff;
    font-family: 'Press Start 2P', monospace;
    font-size: 18px;
    box-shadow: 0 0 20px -4px #f15f2c;
    margin-bottom: 4px;
  }
  .bst-mark-b {
    transform: translateY(1px);
  }

  .bst-heading {
    margin: 0;
    font-family: 'VT323', monospace;
    font-size: 30px;
    line-height: 1.1;
    color: var(--ink);
  }
  .bst-heading .accent {
    color: #f15f2c;
  }
  .bst-pitch {
    margin: 0;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
    max-width: 48ch;
  }
  .bst-actions {
    margin-top: 4px;
  }

  /* Right column — perks list */
  .bst-perks {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 14px 18px;
    background: color-mix(in oklab, #f15f2c 6%, var(--code-bg));
    border: 1px solid color-mix(in oklab, #f15f2c 30%, var(--border));
    border-radius: 3px;
    display: grid;
    gap: 8px;
  }
  .bst-perks li {
    display: flex;
    gap: 8px;
    align-items: baseline;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--ink);
    line-height: 1.5;
  }
  .bst-perk-marker {
    color: #f15f2c;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Boosty button override — orange instead of default pink accent. */
  .bst-card .btn.primary {
    background: #f15f2c;
    border-color: #f15f2c;
    color: #fff;
  }
  .bst-card .btn.primary:hover {
    background: #ff7942;
    border-color: #ff7942;
    box-shadow: 0 10px 28px -12px #f15f2c;
  }

  @media (max-width: 760px) {
    .bst-card {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
</style>
