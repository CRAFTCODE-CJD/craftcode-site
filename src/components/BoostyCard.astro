---
/**
 * Boosty subscription card for the home page.
 *
 * Boosty is a paywalled content platform — subscribers get local access
 * to project files, tutorials, and early builds. The card explains
 * WHAT a subscription unlocks, not "how to use Boosty" (its a storefront,
 * not documentation). Keep copy concrete: what kinds of files/projects
 * are behind the paywall.
 */
import AsciiLogo from './AsciiLogo.astro';

interface Props {
  url?: string;
  /** Short list of what subscribers get — update as content ships. */
  perks?: string[];
}

const {
  url = 'https://boosty.to/channel-jonathan-developer',
  perks = [
    'Исходники к туториалам YouTube',
    'Бета-доступ к будущим плагинам',
    'Проекты-песочницы для экспериментов',
  ],
} = Astro.props;
---

<section class="bst-card" aria-label="Boosty">
  <a class="bst-link" href={url} target="_blank" rel="noopener">
    <div class="bst-header">
       <span class="ds-label">// boosty</span>
    </div>
    
    <div class="bst-mark-container">
      <AsciiLogo type="boosty" />
    </div>

    <div class="bst-footer">
       <span class="bst-action-label">Get Sources <span>→</span></span>
    </div>
  </a>
</section>

<style>
  .bst-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .bst-card:hover {
    transform: translateY(-2px);
    border-color: #f15f2c;
    box-shadow: 0 0 20px -10px rgba(241, 95, 44, 0.3);
  }
  .bst-link {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 12px 16px;
  }
  .bst-header {
    margin-bottom: 8px;
  }
  .bst-mark-container {
    height: 70px;
    display: grid;
    place-items: center;
    background: color-mix(in oklab, #f15f2c 3%, #000);
    border-radius: 4px;
    border: 1px solid color-mix(in oklab, #f15f2c 10%, transparent);
    transition: background 0.2s;
  }
  .bst-card:hover .bst-mark-container {
    background: color-mix(in oklab, #f15f2c 8%, #000);
  }
  .bst-mark {
    display: inline-grid;
    place-items: center;
    width: 40px; height: 40px;
    border-radius: 8px;
    background: #f15f2c;
    color: #fff;
    font-family: 'Press Start 2P', 'IBM Plex Mono', monospace;
    font-size: 20px;
    box-shadow: 0 0 15px -2px #f15f2c;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .bst-card:hover .bst-mark {
    transform: scale(1.1);
    box-shadow: 0 0 20px 0px #f15f2c;
  }
  .bst-mark-b {
    transform: translateY(1px);
  }
  .bst-footer {
     margin-top: 10px;
     display: flex;
     justify-content: flex-end;
  }
  .bst-action-label {
     font-family: 'JetBrains Mono', monospace;
     font-size: 11px;
     color: rgba(241, 95, 44, 0.8);
     text-transform: uppercase;
     letter-spacing: 0.05em;
     transition: color 0.2s;
  }
  .bst-card:hover .bst-action-label {
    color: #f15f2c;
  }
  .bst-action-label span {
    display: inline-block;
    transition: transform 0.2s;
  }
  .bst-card:hover .bst-action-label span {
    transform: translateX(4px);
  }
</style>
