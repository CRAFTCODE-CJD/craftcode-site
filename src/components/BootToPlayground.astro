---
/**
 * Home-only hero: a single bordered stage that first displays a CRT-style
 * typewriter boot sequence, then smoothly morphs into an interactive
 * workshop playground with the two robots, obstacles, and HUD.
 *
 * The stage (border, background, grid, glow) is ONE box across both
 * phases — only the contents cross-fade + scale. That gives the user
 * the feeling that the terminal window "transforms" into the robot
 * window without layout jumping.
 *
 * Phase transition is triggered by a single-session typing animation
 * that fires once per tab (sessionStorage). Returning visitors see the
 * playground immediately.
 *
 * Companions physics (src/scripts/companions.js) auto-initialises on
 * DOMContentLoaded when it finds `.companions` in the DOM. This
 * component is the only place that renders `.companions`, so the
 * playground exists only on home. Other pages never load the physics.
 */
---

<section class="cc-stage" id="cc-stage" data-phase="boot" aria-label="Workshop boot">
  <!-- ── Phase 1: boot-terminal (CRT typewriter) ──
       Just the loading log, centered in the stage — the CRAFTCODE
       wordmark lives in phase 2 where it labels the workshop. -->
  <div class="cc-stage-log" aria-hidden="true">
    <pre id="boot-log"></pre>
  </div>

  <!-- ── Phase 2: playground (obstacles + bots + HUD) ── -->
  <div class="cc-stage-play" aria-hidden="true">
    <div class="companions-caption">
      // workshop · drag a robot and toss it · they bump into things
    </div>
    <div class="companions-hud">
      <span><span class="k">bots</span> <span class="v">2</span></span>
      <span><span class="k">rapport</span> <span class="v" id="hud-rapport">50</span></span>
      <span><span class="k">bumps</span> <span class="v" id="hud-bumps">0</span></span>
    </div>

    <!-- Decorative CRAFTCODE wordmark: lives in the playground phase as a
         background sign the robots work under. Pointer-events: none so it
         doesn't intercept drags on the robots or obstacles. -->
    <div class="cc-stage-sign" aria-hidden="true">
      <span class="cc-stage-sign-word"><span class="sign-pink">CRAFT</span><span class="sign-yell">CODE</span></span>
      <span class="cc-stage-sign-tag">// мастерская двух роботов</span>
    </div>

    <!-- Obstacles live INSIDE .companions so the physics refreshObstacles()
         scan (which scopes to the companions container) can measure them. -->
    <div class="companions" aria-live="polite" aria-atomic="false">
      <div class="companions-obstacle" data-ob
           style="left: 20%; top: 210px; width: 80px; height: 14px;">
        <span class="obstacle-lbl">// crate_01</span>
      </div>
      <div class="companions-obstacle" data-ob
           style="left: 50%; top: 140px; width: 14px; height: 80px;">
        <span class="obstacle-lbl">// pillar_02</span>
      </div>
      <div class="companions-obstacle" data-ob
           style="right: 14%; top: 230px; width: 110px; height: 12px;">
        <span class="obstacle-lbl">// shelf_03</span>
      </div>
      <div class="companion" data-who="craft" role="button" tabindex="0"
           aria-label="CRAFT — press Enter to talk.">
        <div class="sprite"></div>
        <div class="companion-bubble" id="bubble-craft"></div>
      </div>
      <div class="companion" data-who="code" role="button" tabindex="0"
           aria-label="CODE — press Enter to talk.">
        <div class="sprite"></div>
        <div class="companion-bubble" id="bubble-code"></div>
      </div>
    </div>
  </div>

  <!-- FX overlay for dust / shock / sparkles generated by companions.js -->
  <div class="fx-layer" aria-hidden="true"></div>
</section>

<!-- Boot typewriter + phase-transition driver -->
<script is:inline>
  (() => {
    const stage = document.getElementById('cc-stage');
    const log   = document.getElementById('boot-log');
    if (!stage || !log) return;

    const lines = [
      '> BOOT SEQUENCE ................... [OK]',
      '> LOADING /craft/...............  [OK]',
      '> LOADING /code/................  [OK]',
      '> LINK SPRITE_SHEETS ...........  [OK]',
      '> MOUNT DIALOGUE_ENGINE ........  [OK]',
      '> ACCENT.PIGMENT == MAGENTA ....  [OK]',
      '> ROBOTS.READY ................. true',
    ];

    const toPlayground = () => {
      stage.dataset.phase = 'playground';
      // Tell companions.js it can stop idle-sleeping once the playground is live.
      if (window.__companions && typeof window.__companions.init === 'function'
          && !window.__companions._started) {
        window.__companions.init();
        window.__companions._started = true;
      }
    };

    // Animation fires on every page load — there is no "skip" path.
    // (Previously gated by sessionStorage, but users wanted the morph
    //  each time they return to the home page.)

    let i = 0, j = 0;
    const type = () => {
      if (i >= lines.length) {
        // Short pause so the reader sees the full log, then morph.
        setTimeout(toPlayground, 650);
        return;
      }
      const full = lines[i];
      if (j <= full.length) {
        log.textContent =
          lines.slice(0, i).join('\n') + (i ? '\n' : '') + full.slice(0, j);
        j++;
        const ch = full[j] || '';
        setTimeout(type, ch === '.' ? 10 : 18);
      } else {
        i++; j = 0;
        setTimeout(type, 120);
      }
    };
    setTimeout(type, 200);
  })();
</script>

<!-- Load the companions physics/dialogue engine. It auto-inits on
     DOMContentLoaded; the boot-phase driver above re-calls init() once
     the stage transitions to the playground phase. Loaded only on home. -->
<script>
  import '~/scripts/companions.js';
</script>

<style>
  .cc-stage {
    position: relative;
    /* Sit close to the topbar — user feedback was that the stage floated
       far below the navigation with a lot of empty dark space above it.
       Reduced top margin from 24px → 0; also tightened bottom margin. */
    margin: 0 auto 32px;
    width: calc(100% - 24px);
    max-width: 1080px;
    height: 320px;
    border: 1px solid color-mix(in oklab, var(--accent) 45%, var(--border));
    border-radius: var(--radius, 6px);
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 50% 100%,
        color-mix(in oklab, var(--accent-2) 10%, transparent), transparent 70%),
      repeating-linear-gradient(to right,
        color-mix(in oklab, var(--accent-2) 4%, transparent) 0 1px,
        transparent 1px 40px),
      repeating-linear-gradient(to bottom,
        color-mix(in oklab, var(--accent) 4%, transparent) 0 1px,
        transparent 1px 40px),
      linear-gradient(to bottom, var(--surface), var(--code-bg));
    box-shadow:
      inset 0 0 60px rgba(0, 0, 0, 0.5),
      0 0 32px color-mix(in oklab, var(--accent) 10%, transparent);
  }

  /* Dashed floor line — stays across both phases for continuity. */
  .cc-stage::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 2px;
    background: repeating-linear-gradient(
      to right,
      var(--accent) 0 8px,
      transparent 8px 16px
    );
    opacity: 0.55;
    pointer-events: none;
    z-index: 1;
  }

  /* Both phase-layers fill the stage box. Opacity + scale cross-fade. */
  .cc-stage-log,
  .cc-stage-play {
    position: absolute;
    inset: 0;
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  /* Phase: boot (default) — text visible, playground hidden.
     Both rows (log + title) are centered vertically AND horizontally so
     the typewriter feels like it's being typed into a CRT screen, not
     pinned to the left edge. */
  .cc-stage-log {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 20px;
    opacity: 1;
    text-align: center;
  }
  .cc-stage[data-phase='playground'] .cc-stage-log {
    opacity: 0;
    transform: scale(0.98);
    pointer-events: none;
  }

  #boot-log {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.7;
    color: var(--accent-2);
    white-space: pre;                 /* preserve dots alignment across lines */
    text-align: left;                 /* but keep each line left-justified inside the centered block */
    text-shadow: 0 0 6px color-mix(in oklab, var(--accent-2) 60%, transparent);
    display: inline-block;            /* shrink to content so parent flex can center it */
  }
  #boot-log::after {
    content: '▮';
    color: var(--accent);
    animation: cc-cursor-blink 0.9s steps(2) infinite;
  }
  @keyframes cc-cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Playground wordmark — background "signage" above the workbench.
     Sits behind obstacles/robots (z-index below .companions) and never
     intercepts pointer events. Pink CRAFT + yellow CODE mirrors the
     topbar wordmark so the brand reads immediately.

     Positioned top-center with a little air above. The tagline sits
     directly under the wordmark. Opacity is muted so the robots and
     obstacles remain the primary read. */
  .cc-stage-sign {
    position: absolute;
    top: 34px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    pointer-events: none;
    z-index: 2;          /* above stage bg, below companions (z: 5) */
    text-align: center;
    opacity: 0.92;
  }
  .cc-stage-sign-word {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(28px, 4.4vw, 48px);
    line-height: 1.05;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-shadow:
      0 0 14px color-mix(in oklab, var(--accent) 60%, transparent),
      2px 2px 0 rgba(0, 0, 0, 0.55);
  }
  .cc-stage-sign-word .sign-pink { color: var(--accent);   margin-right: 2px; }
  .cc-stage-sign-word .sign-yell { color: var(--accent-2); }
  .cc-stage-sign-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--muted);
    text-transform: lowercase;
  }

  /* Phase: playground — hidden during boot, revealed after transition. */
  .cc-stage-play {
    opacity: 0;
    transform: scale(1.02);
    pointer-events: none;
  }
  .cc-stage[data-phase='playground'] .cc-stage-play {
    opacity: 1;
    transform: scale(1);
    /* Delay the fade-in slightly so boot has started fading first. */
    transition-delay: 0.15s;
    pointer-events: auto;
  }

  @media (max-width: 760px) {
    .cc-stage { height: 260px; margin-top: 16px; }
    #boot-log { font-size: 12px; min-height: 120px; }
    .cc-stage-tag { font-size: 11px; }
  }
</style>
