---
import TypingText from '~/components/TypingText.astro';
---

<section class="cc-stage" id="cc-stage" data-phase="boot" aria-label="Workshop boot">
  <!-- ── Phase 1: boot-terminal (CRT typewriter) ──
       Just the loading log, centered in the stage — the CRAFTCODE
       wordmark lives in phase 2 where it labels the workshop. -->
  <div class="cc-stage-log" aria-hidden="true">
    <pre id="boot-log"></pre>
  </div>

  <!-- ── Phase 2: playground (obstacles + bots + HUD) ── -->
  <div class="cc-stage-play" aria-hidden="true" data-camera="follow">
    <div class="companions-caption">
      // workshop · drag a robot and toss it · they bump into things
    </div>
    <div class="companions-hud">
      <span><span class="k">bots</span> <span class="v">2</span></span>
      <span><span class="k">rapport</span> <span class="v" id="hud-rapport">50</span></span>
      <span><span class="k">bumps</span> <span class="v" id="hud-bumps">0</span></span>
      <span class="hud-hint">press <kbd>/</kbd> for terminal</span>
    </div>

    <!-- Decorative CRAFTCODE wordmark: lives in the playground phase as a
         background sign the robots work under. Pointer-events: none so it
         doesn't intercept drags on the robots or obstacles. -->
    <div class="cc-stage-sign" aria-hidden="true">
      <span class="cc-stage-sign-word glitch-hover"><span class="sign-pink">CRAFT</span><span class="sign-yell">CODE</span></span>
      <div class="cc-stage-sign-tag opacity-80">
        <TypingText text="Инструменты и шаблоны для UE" speed={70} delay={1500} />
      </div>
    </div>

    <!-- Camera wrapper — scales/translates the entire workshop so both
         companions always stay framed. Physics still runs in .companions
         coords; getBoundingClientRect() on .companions naturally accounts
         for this transform, so drag/throw math remains correct as long as
         the camera is frozen during an active drag (see bot.camera.ts). -->
    <div class="cc-stage-camera" data-cc-cam-scale="1" data-cc-cam-tx="0" data-cc-cam-ty="0">
    <!-- Obstacles live INSIDE .companions so the physics refreshObstacles()
         scan (which scopes to the companions container) can measure them. -->
    <div class="companions" aria-live="polite" aria-atomic="false">
      <!-- A low step on the left — reachable via a normal jump from ground.
           Stage is 420px tall; ground line ≈ 419. A jump clears ~60 px, so
           a step_01 top at 360 keeps it trivially stepable. -->
      <div class="companions-obstacle" data-ob data-dynamic="hover"
           style="left: 8%; top: 360px; width: 130px; height: 28px;">
        <span class="obstacle-lbl">// step_01</span>
      </div>
      <!-- A floating platform in the middle, reachable with a running jump
           off step_01 (gap ≈ 90 px, height drop ≈ 70 px). -->
      <div class="companions-obstacle" data-ob data-dynamic="slide"
           style="left: 38%; top: 290px; width: 150px; height: 14px;">
        <span class="obstacle-lbl">// floating_02</span>
      </div>
      <!-- A higher platform on the right. From floating_02 the bot can hop
           up (platform tops differ by only ~60 px). -->
      <div class="companions-obstacle" data-ob
           style="right: 9%; top: 230px; width: 150px; height: 22px;">
        <span class="obstacle-lbl">// crate_03</span>
      </div>
      
      <!-- Interactive floor button -->
      <div class="companions-button" id="cc-floor-btn"
           style="position: absolute; left: 50%; bottom: 0; width: 40px; height: 10px; background: var(--accent); border-radius: 5px 5px 0 0; z-index: 1;">
      </div>
      <div class="companion" data-who="craft" role="button" tabindex="0"
           aria-label="CRAFT — press Enter to talk.">
        <div class="sprite"></div>
        <div class="companion-bubble" id="bubble-craft"></div>
      </div>
      <div class="companion" data-who="code" role="button" tabindex="0"
           aria-label="CODE — press Enter to talk.">
        <div class="sprite"></div>
        <div class="companion-bubble" id="bubble-code"></div>
      </div>
    </div>
    <!-- FX overlay for dust / shock / sparkles generated by companions.js.
         Lives INSIDE .cc-stage-camera (sibling of .companions) so that the
         camera's translate+scale transform is applied to FX too — otherwise
         dust/shock rendered at a bot's feet in physics-coords would drift
         off-target after the camera zooms in. -->
    <div class="fx-layer" aria-hidden="true"></div>
    </div><!-- /.cc-stage-camera -->
  </div>
</section>

<!-- Boot typewriter + phase-transition driver -->
<script is:inline>
  (() => {
    const stage = document.getElementById('cc-stage');
    const log   = document.getElementById('boot-log');
    if (!stage || !log) return;

    const lines = [
      '> BOOT SEQUENCE ................... [OK]',
      '> LOADING /craft/...............  [OK]',
      '> LOADING /code/................  [OK]',
      '> LINK SPRITE_SHEETS ...........  [OK]',
      '> MOUNT DIALOGUE_ENGINE ........  [OK]',
      '> ACCENT.PIGMENT == MAGENTA ....  [OK]',
      '> ROBOTS.READY ................. true',
    ];

    const toPlayground = () => {
      stage.dataset.phase = 'playground';
      // Tell companions.js it can stop idle-sleeping once the playground is live.
      if (window.__companions && typeof window.__companions.init === 'function'
          && !window.__companions._started) {
        window.__companions.init();
        window.__companions._started = true;
      }
    };

    // Animation fires on every page load — there is no "skip" path.
    // (Previously gated by sessionStorage, but users wanted the morph
    //  each time they return to the home page.)

    let i = 0, j = 0;
    const type = () => {
      if (i >= lines.length) {
        // Short pause so the reader sees the full log, then morph.
        setTimeout(toPlayground, 650);
        return;
      }
      const full = lines[i];
      if (j <= full.length) {
        log.textContent =
          lines.slice(0, i).join('\n') + (i ? '\n' : '') + full.slice(0, j);
        j++;
        const ch = full[j] || '';
        setTimeout(type, ch === '.' ? 10 : 18);
      } else {
        i++; j = 0;
        setTimeout(type, 120);
      }
    };
    setTimeout(type, 200);
  })();
</script>

<!-- Load the companions physics/dialogue engine. It auto-inits on
     DOMContentLoaded; the boot-phase driver above re-calls init() once
     the stage transitions to the playground phase. Loaded only on home. -->
<script>
  import '~/bots/bot.engine';
</script>

<style>
  .cc-stage {
    position: relative;
    margin: 0 auto 40px;
    width: 100%;
    /* Increase height from 320px to 420px to give robots more room to fall/toss */
    height: 420px;
    border: 2px solid color-mix(in oklab, var(--accent) 55%, var(--border));
    border-radius: 12px;
    overflow: hidden;
    background:
      radial-gradient(ellipse 90% 70% at 50% 100%,
        color-mix(in oklab, var(--accent-2) 15%, transparent), transparent 75%),
      repeating-linear-gradient(to right,
        color-mix(in oklab, var(--accent-2) 6%, transparent) 0 1px,
        transparent 1px 40px),
      repeating-linear-gradient(to bottom,
        color-mix(in oklab, var(--accent) 6%, transparent) 0 1px,
        transparent 1px 40px),
      linear-gradient(to bottom, var(--surface), var(--code-bg));
    box-shadow:
      inset 0 0 80px rgba(0, 0, 0, 0.6),
      0 0 40px color-mix(in oklab, var(--accent) 15%, transparent);
  }

  /* Dashed neon floor line + warm glow. `::before` is a warm glow pad that
     reads as "ground haze"; `::after` is the crisp dashed stripe. Both are
     pointer-events: none and sit below companions (z=10). */
  .cc-stage::before {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 80px;
    background:
      linear-gradient(to top,
        color-mix(in oklab, var(--accent) 22%, transparent) 0%,
        color-mix(in oklab, var(--accent-2) 8%, transparent) 40%,
        transparent 100%);
    pointer-events: none;
    z-index: 1;
    opacity: 0.9;
  }
  .cc-stage::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 4px;
    background: repeating-linear-gradient(
      to right,
      var(--accent) 0 12px,
      transparent 12px 24px
    );
    opacity: 0.85;
    pointer-events: none;
    z-index: 1;
    box-shadow:
      0 -2px 10px color-mix(in oklab, var(--accent) 55%, transparent),
      0 -8px 30px color-mix(in oklab, var(--accent) 30%, transparent);
  }

  /* Both phase-layers fill the stage box. Opacity + scale cross-fade. */
  .cc-stage-log,
  .cc-stage-play {
    position: absolute;
    inset: 0;
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  /* Phase: boot (default) — text visible, playground hidden.
     Both rows (log + title) are centered vertically AND horizontally so
     the typewriter feels like it's being typed into a CRT screen, not
     pinned to the left edge. */
  .cc-stage-log {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 20px;
    opacity: 1;
    text-align: center;
  }
  .cc-stage[data-phase='playground'] .cc-stage-log {
    opacity: 0;
    transform: scale(0.98);
    pointer-events: none;
  }

  #boot-log {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.7;
    color: var(--accent-2);
    white-space: pre;                 /* preserve dots alignment across lines */
    text-align: left;                 /* but keep each line left-justified inside the centered block */
    text-shadow: 0 0 6px color-mix(in oklab, var(--accent-2) 60%, transparent);
    display: inline-block;            /* shrink to content so parent flex can center it */
  }
  #boot-log::after {
    content: '▮';
    color: var(--accent);
    animation: cc-cursor-blink 0.9s steps(2) infinite;
  }
  @keyframes cc-cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Playground wordmark — background "signage" above the workbench.
     Sits behind obstacles/robots (z-index below .companions) and never
     intercepts pointer events. Pink CRAFT + yellow CODE mirrors the
     topbar wordmark so the brand reads immediately.

     Positioned top-center with a little air above. The tagline sits
     directly under the wordmark. Opacity is muted so the robots and
     obstacles remain the primary read. */
  .cc-stage-sign {
    position: absolute;
    top: 34px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    pointer-events: none;
    z-index: 2;          /* above stage bg, below companions (z: 5) */
    text-align: center;
    opacity: 0.92;
  }
  .cc-stage-sign-word {
    font-family: 'Press Start 2P', 'Rubik Pixels', monospace;
    font-size: clamp(28px, 4.4vw, 48px);
    line-height: 1.05;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-shadow:
      0 0 14px color-mix(in oklab, var(--accent) 60%, transparent),
      2px 2px 0 rgba(0, 0, 0, 0.55);
  }
  .cc-stage-sign-word .sign-pink { color: var(--accent);   margin-right: 2px; }
  .cc-stage-sign-word .sign-yell { color: var(--accent-2); }
  .cc-stage-sign-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--muted);
    text-transform: lowercase;
  }

  /* Phase: playground — hidden during boot, revealed after transition. */
  .cc-stage-play {
    opacity: 0;
    transform: scale(1.02);
    pointer-events: none;
  }
  .cc-stage[data-phase='playground'] .cc-stage-play {
    opacity: 1;
    transform: scale(1);
    /* Delay the fade-in slightly so boot has started fading first. */
    transition-delay: 0.15s;
    pointer-events: auto;
  }

  @media (max-width: 760px) {
    .cc-stage { height: 320px; margin-top: 16px; }
    #boot-log { font-size: 11px; min-height: 120px; }
    .cc-stage-tag { font-size: 11px; }
    /* Hide obstacles' text labels on mobile — they clip into captions */
    .companions-obstacle .obstacle-lbl { display: none; }
    /* Lift obstacles higher so they don't overlap the wordmark */
    .cc-stage-sign { top: 20px; }
    .cc-stage-sign-word { font-size: clamp(22px, 8vw, 32px); }
    .cc-stage-sign-tag { font-size: 10px; }
  }
  @media (max-width: 480px) {
    .cc-stage { height: 280px; }
    /* Companions HUD on very narrow screens: compact layout */
    .companions-hud { font-size: 9px; gap: 8px; bottom: 6px; right: 8px; }
    .companions-caption { font-size: 10px; top: 6px; left: 8px; right: 8px; }
  }
</style>
