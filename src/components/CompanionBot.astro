---
/**
 * CompanionBot — static mini-preview of the CRAFT/CODE sprite with a
 * looping sub-clip of frames. Renders the real sprite sheet so the
 * robot looks alive even outside the interactive playground.
 */
interface Props {
  bot?: 'craft' | 'code';
  anim?: 'typing' | 'hammer' | 'progress' | 'sleep' | 'idle' | 'wave' | 'think';
  size?: number;
  class?: string;
}
const { bot = 'code', anim = 'idle', size = 56, class: className } = Astro.props;

// Frame indices map 1:1 to src/bots/frames.data.js FRAME_ORDER.
const CLIP: Record<string, { from: number; to: number; ms: number }> = {
  idle:     { from: 0,  to: 1,  ms: 900 },   // idle_a, idle_b
  wave:     { from: 43, to: 44, ms: 320 },   // wave_a, wave_b
  typing:   { from: 46, to: 47, ms: 220 },   // typing_a, typing_b
  hammer:   { from: 52, to: 54, ms: 280 },   // hammer_up, _mid, _strike
  think:    { from: 62, to: 63, ms: 520 },   // think_a, think_b
  progress: { from: 55, to: 59, ms: 480 },   // bar_0..bar_check
  sleep:    { from: 89, to: 91, ms: 900 },   // sleep, sleep_1z, sleep_3z
};
const c = CLIP[anim] ?? CLIP.idle;
const frames = c.to - c.from + 1;
---

<div
  class:list={['cb-bot', className]}
  style={`--cb-size: ${size}px; --cb-from: ${c.from}; --cb-to: ${c.to};`}
  data-who={bot}
  aria-hidden="true"
>
  <span
    class="cb-sprite"
    style={`animation: cb-sheet ${c.ms}ms steps(${frames}) infinite;`}
  ></span>
  <span class="cb-scan"></span>
</div>

<style>
  .cb-bot {
    --cb-size: 56px;
    position: relative;
    display: inline-grid;
    place-items: center;
    width: var(--cb-size);
    height: var(--cb-size);
    padding: 4px;
    background: var(--code-bg);
    border: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border));
    border-radius: 6px;
    box-shadow:
      inset 0 0 12px color-mix(in oklab, var(--accent) 15%, transparent),
      var(--glow-sm);
    overflow: hidden;
  }
  .cb-sprite {
    display: block;
    width: 48px;
    height: 48px;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    background-repeat: no-repeat;
    /* Sheet is 92 frames × 48px = 4416px */
    background-size: 4416px 48px;
    background-position-x: calc(var(--cb-from, 0) * -48px);
  }
  .cb-bot[data-who='craft'] .cb-sprite { background-image: url('/sprites/craft.png'); }
  .cb-bot[data-who='code']  .cb-sprite { background-image: url('/sprites/code.png'); }

  /* Single shared keyframe — animates background-position-x from the
     first frame of the clip (inclusive) to one-past-last (exclusive).
     Combined with `steps(N)` on the element, this shows each of the
     N frames discretely without sub-pixel bleed. */
  @keyframes cb-sheet {
    from { background-position-x: calc(var(--cb-from, 0) * -48px); }
    to   { background-position-x: calc((var(--cb-to, 0) + 1) * -48px); }
  }

  .cb-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent 40%, color-mix(in oklab, var(--accent-3) 18%, transparent) 50%, transparent 60%);
    background-size: 100% 200%;
    animation: cb-scan 3s linear infinite;
    mix-blend-mode: screen;
    opacity: 0.6;
  }
  @keyframes cb-scan {
    from { background-position: 0 100%; }
    to   { background-position: 0 -100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cb-sprite, .cb-scan { animation: none; }
  }
</style>
