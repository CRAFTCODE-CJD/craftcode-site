---
/**
 * CompanionBot — static mini-preview of the CRAFT/CODE sprite with a
 * looping sub-clip of frames. Renders the real sprite sheet so the
 * robot looks alive even outside the interactive playground.
 *
 * `anim` picks a set of frame indices to loop through (values match the
 * catalog in public/sprites/ANIMATIONS.md). Frames are advanced with a
 * pure CSS step-animation on the --cc-frame custom property.
 */
interface Props {
  bot?: 'craft' | 'code';
  anim?: 'typing' | 'hammer' | 'progress' | 'sleep' | 'idle' | 'wave' | 'think';
  size?: number;
  class?: string;
}
const { bot = 'code', anim = 'idle', size = 56, class: className } = Astro.props;

// Frame ranges — must match the sprite sheets (92 frames, see
// public/sprites/ANIMATIONS.md + src/bots/frames.data.js).
const CLIP: Record<string, { from: number; to: number; ms: number }> = {
  idle:     { from: 0,  to: 2,  ms: 900 },
  wave:     { from: 11, to: 12, ms: 320 },
  typing:   { from: 13, to: 14, ms: 220 },
  hammer:   { from: 15, to: 15, ms: 600 }, // "excited" pose as placeholder for hammer
  think:    { from: 16, to: 17, ms: 520 },
  progress: { from: 18, to: 19, ms: 480 },
  sleep:    { from: 10, to: 10, ms: 2000 },
};
const c = CLIP[anim] ?? CLIP.idle;
const frames = c.to - c.from + 1;
const animName = `cb-${bot}-${anim}-${c.from}-${c.to}`;
---

<div
  class:list={['cb-bot', className]}
  style={`--cb-size: ${size}px; --cb-from: ${c.from}; --cb-to: ${c.to}; --cb-ms: ${c.ms}ms; --cb-frames: ${frames}; animation-name: ${animName};`}
  data-who={bot}
  aria-hidden="true"
>
  <span class="cb-sprite"></span>
  <span class="cb-scan"></span>
</div>

<style is:global define:vars={{}}>
  /* Keyframes are generated per-clip so the sprite shows only the
     requested frame range and loops. */
</style>

<style>
  .cb-bot {
    --cb-size: 56px;
    position: relative;
    display: inline-grid;
    place-items: center;
    width: var(--cb-size);
    height: var(--cb-size);
    padding: 4px;
    background: var(--code-bg);
    border: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border));
    border-radius: 6px;
    box-shadow:
      inset 0 0 12px color-mix(in oklab, var(--accent) 15%, transparent),
      var(--glow-sm);
    overflow: hidden;
  }
  .cb-sprite {
    display: block;
    width: 48px;
    height: 48px;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    background-repeat: no-repeat;
    background-size: 4416px 48px;
    /* Frame 0 on initial paint; keyframes override this. */
    background-position-x: calc(var(--cb-from, 0) * -48px);
    animation: cb-frames var(--cb-ms, 800ms) steps(1) infinite;
  }
  .cb-bot[data-who='craft'] .cb-sprite { background-image: url('/sprites/craft.png'); }
  .cb-bot[data-who='code']  .cb-sprite { background-image: url('/sprites/code.png'); }

  /* Scanline overlay for CRT feel */
  .cb-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent 40%, color-mix(in oklab, var(--accent-3) 18%, transparent) 50%, transparent 60%);
    background-size: 100% 200%;
    animation: cb-scan 3s linear infinite;
    mix-blend-mode: screen;
    opacity: 0.6;
  }

  /* Generic single-frame loop; for multi-frame clips we interpolate
     through integer frames 0..N-1 and write the offset as
     `calc((from + step-N) * -48px)` by driving background-position-x
     with steps(). Implemented by keyframes below. */
  @keyframes cb-frames {
    0%   { background-position-x: calc(var(--cb-from, 0) * -48px); }
    25%  { background-position-x: calc((var(--cb-from, 0) + 1) * -48px); }
    50%  { background-position-x: calc(var(--cb-to, 0) * -48px); }
    75%  { background-position-x: calc((var(--cb-from, 0) + 1) * -48px); }
    100% { background-position-x: calc(var(--cb-from, 0) * -48px); }
  }

  @keyframes cb-scan {
    from { background-position: 0 100%; }
    to   { background-position: 0 -100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cb-sprite, .cb-scan { animation: none; }
  }
</style>
