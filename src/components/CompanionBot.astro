---
interface Props {
  bot?: 'craft' | 'code';
  anim?: 'typing' | 'hammer' | 'progress' | 'sleep' | 'idle';
  class?: string;
}

const { bot = 'code', anim = 'idle', class: className } = Astro.props;
---

<div class:list={['bot-window', className]}>
  <div class="bot-header">
    <span class="bot-dot"></span>
    <span class="bot-label">{bot.toUpperCase()} :: {anim.toUpperCase()}</span>
  </div>
  <div class:list={[
    'bot-ui',
    `bot-${bot}`,
    `anim-ui-${anim}`
  ]} aria-hidden="true"></div>
  <div class="bot-scan"></div>
</div>

<style>
  .bot-window {
    position: relative;
    padding: 6px;
    background: #000;
    border: 1px solid var(--border);
    border-radius: 4px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    overflow: hidden;
  }
  .bot-header {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--grid);
    padding-bottom: 2px;
  }
  .bot-dot {
    width: 3px; height: 3px;
    background: var(--link);
    border-radius: 50%;
    box-shadow: 0 0 4px var(--link);
  }
  .bot-label {
    font-family: var(--font-mono);
    font-size: 6px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .bot-scan {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0, 243, 255, 0.05) 50%, transparent 60%);
    background-size: 100% 200%;
    animation: bot-scan-anim 3s linear infinite;
    pointer-events: none;
  }
  @keyframes bot-scan-anim {
    from { background-position: 0 100%; }
    to { background-position: 0 -100%; }
  }
</style>
