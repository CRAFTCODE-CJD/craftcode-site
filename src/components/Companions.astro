---
/**
 * Companions — site-wide terminal mount + bot engine wiring.
 *
 * Runtime is split across src/bots/:
 *   · kaplay.engine.ts          — KAPLAY physics + rendering (home only)
 *   · kaplay.dialogue-bridge.ts — installs window.__dialogue / __companions
 *   · bot.engine.ts             — typed facade + BotState machine
 *   · bot.ai.ts                 — simulated AI keyword dispatcher
 *   · bot.terminal.ts           — fake terminal overlay (hotkey: `/`)
 *
 * On the home page <KaplayPlayground /> renders the interactive workshop.
 * Everywhere else only the fake-terminal overlay is exposed — the KAPLAY
 * surface is not mounted, and window.__companions stays undefined (terminal
 * dispatch paths gracefully no-op). The JS API on window.__bots stays live.
 */
---

<div class="companions companions--bare" aria-hidden="true">
  <div class="companions-terminal" data-terminal-mount></div>
</div>

<script>
  // Mobile gate — the terminal overlay is hidden by CSS at <=768px, the bots
  // never appear there, and bot.easter wires up keyboard combos that no phone
  // user will hit. Skipping the imports avoids ~12 KB of script + sprite
  // fetches on every mobile pageload.
  const isMobile = typeof window !== 'undefined'
    && window.matchMedia('(max-width: 768px)').matches;

  if (!isMobile) {
    Promise.all([
      import('../bots/bot.engine'),
      import('../bots/bot.terminal'),
      import('../bots/bot.easter'),
    ]).then(([_engine, terminal, easter]) => {
      terminal.bindGlobalTerminal();
      easter.bindEasterEggs();
    });
  }
</script>

<style>
  :global(.companions.companions--bare) {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }
  :global(.companions.companions--bare .companions-terminal) {
    pointer-events: auto;
  }
</style>
