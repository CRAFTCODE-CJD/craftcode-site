---
/**
 * Companions — site-wide terminal mount + bot engine wiring.
 *
 * Runtime is split across src/bots/:
 *   · engine.legacy.js  — physics + scene playback
 *   · bot.engine.ts     — typed facade + BotState machine
 *   · bot.ai.ts         — simulated AI keyword dispatcher
 *   · bot.terminal.ts   — fake terminal overlay (hotkey: `/`)
 *
 * On the home page BootToPlayground.astro renders the interactive
 * playground (obstacles + HUD + live sprites). Everywhere else only the
 * fake-terminal overlay is exposed — sprite positions were tuned for the
 * home stage and would float over article content otherwise. The JS APIs
 * (window.__companions / window.__bots) stay live on every page.
 */
---

<div class="companions companions--bare" aria-hidden="true">
  <div class="companions-terminal" data-terminal-mount></div>
</div>

<script>
  import '../bots/bot.engine';
  import { bindGlobalTerminal } from '../bots/bot.terminal';
  import { bindEasterEggs } from '../bots/bot.easter';
  bindGlobalTerminal();
  bindEasterEggs();
</script>

<style>
  :global(.companions.companions--bare) {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }
  :global(.companions.companions--bare .companions-terminal) {
    pointer-events: auto;
  }
</style>
