---
/**
 * FAB Marketplace storefront card for the home page.
 *
 * Mirrors the layout/feel of YoutubeCard / BoostyCard so the three
 * channels (FAB / YouTube / Boosty) read as a consistent trio of
 * storefront tiles. Kept intentionally channel-agnostic — the card
 * doesn't enumerate specific products (plugins/templates/assets),
 * it just points to the seller profile where current offerings live.
 */
import AsciiLogo from './AsciiLogo.astro';

interface Props {
  sellerUrl?: string;
}

const {
  sellerUrl = 'https://www.fab.com/sellers/CRAFTCODE',
} = Astro.props;
---

<section class="fab-card" aria-label="FAB Marketplace">
  <a class="fab-link" href={sellerUrl} target="_blank" rel="noopener">
    <div class="fab-header">
       <span class="ds-label">// fab</span>
    </div>
    
    <div class="fab-mark-container">
      <AsciiLogo type="fab" />
    </div>

    <div class="fab-footer">
       <span class="fab-action-label">Marketplace <span>→</span></span>
    </div>
  </a>
</section>

<style>
  .fab-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .fab-card:hover {
    transform: translateY(-2px);
    border-color: #00b4d8;
    box-shadow: 0 0 20px -10px rgba(0, 180, 216, 0.3);
  }
  .fab-link {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 12px 16px;
  }
  .fab-header {
    margin-bottom: 8px;
  }
  .fab-mark-container {
    height: 70px;
    display: grid;
    place-items: center;
    background: color-mix(in oklab, #00b4d8 3%, #000);
    border-radius: 4px;
    border: 1px solid color-mix(in oklab, #00b4d8 10%, transparent);
    transition: background 0.2s;
  }
  .fab-card:hover .fab-mark-container {
    background: color-mix(in oklab, #00b4d8 8%, #000);
  }
  .fab-mark {
    display: inline-grid;
    place-items: center;
    width: 40px; height: 40px;
    border-radius: 8px;
    background: #00b4d8;
    color: #0a1520;
    font-family: 'Press Start 2P', monospace;
    font-size: 20px;
    box-shadow: 0 0 15px -2px #00b4d8;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .fab-card:hover .fab-mark {
    transform: scale(1.1);
    box-shadow: 0 0 20px 0px #00b4d8;
  }
  .fab-mark-letter {
    transform: translateY(2px);
  }
  .fab-footer {
     margin-top: 10px;
     display: flex;
     justify-content: flex-end;
  }
  .fab-action-label {
     font-family: 'JetBrains Mono', monospace;
     font-size: 11px;
     color: rgba(0, 180, 216, 0.8);
     text-transform: uppercase;
     letter-spacing: 0.05em;
     transition: color 0.2s;
  }
  .fab-card:hover .fab-action-label {
    color: #00b4d8;
  }
  .fab-action-label span {
    display: inline-block;
    transition: transform 0.2s;
  }
  .fab-card:hover .fab-action-label span {
    transform: translateX(4px);
  }
</style>
