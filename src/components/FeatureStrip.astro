---
/**
 * Compact stats strip under the hero. Three at-a-glance facts that
 * establish legitimacy: supported engines, plugin count, where to buy.
 */
---

<section class="fstrip" aria-label="Quick facts">
  <div class="fstrip-item">
    <div class="fstrip-value">UE 4.27 → 5.7</div>
    <div class="fstrip-label">Поддерживаемые движки</div>
  </div>
  <div class="fstrip-item">
    <div class="fstrip-value">3</div>
    <div class="fstrip-label">Released plugins</div>
  </div>
  <div class="fstrip-item">
    <a class="fstrip-value fstrip-link"
       href="https://www.fab.com/sellers/CraftCode"
       target="_blank" rel="noopener">
      FAB Marketplace ↗
    </a>
    <div class="fstrip-label">Покупка + обновления</div>
  </div>
</section>

<style>
  .fstrip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin: 32px 0 16px;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: var(--border);
  }
  .fstrip-item {
    padding: 20px 22px;
    background: var(--surface);
    display: grid;
    gap: 6px;
  }
  .fstrip-value {
    font-family: 'VT323', monospace;
    font-size: 32px;
    color: var(--accent-2);
    line-height: 1;
  }
  .fstrip-link {
    text-decoration: none;
    transition: color 0.15s;
  }
  .fstrip-link:hover { color: var(--accent); }
  .fstrip-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (max-width: 720px) {
    .fstrip { grid-template-columns: 1fr; }
  }
</style>
