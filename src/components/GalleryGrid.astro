---
/**
 * Asymmetric screenshot gallery. First cell spans 2 rows (hero shot),
 * remaining cells fill a 2-column grid on the right.
 * Adapted from the ClaudeDesigner plugin-page-layouts mockup.
 */
interface Shot {
  src: string;
  caption: string;     // short label shown bottom-left of the cell
  n?: string;          // optional number / tag prefixed before caption
}
interface Props {
  title?: string;
  shots: Shot[];       // at least 3 recommended; first = hero cell
}
const { title, shots } = Astro.props;
---

<section class="gallery">
  {title && <h2 class="gallery-title">{title}</h2>}
  <div class="gallery-grid">
    {shots.map((s, i) => (
      <a
        class:list={['gallery-cell', i === 0 && 'hero']}
        href={s.src}
        target="_blank"
        rel="noopener"
        style={`background-image: url('${s.src}');`}
        aria-label={s.caption}
      >
        <span class="gallery-cap">
          {s.n && <span class="gallery-cap-n">{s.n}</span>}
          {s.caption}
        </span>
      </a>
    ))}
  </div>
</section>

<style>
  .gallery { margin: 32px 0; }
  .gallery-title {
    font-family: 'VT323', monospace !important;
    font-size: 24px !important;
    text-transform: uppercase;
    color: var(--ink) !important;
    text-shadow: 2px 2px 0 var(--accent) !important;
    margin: 0 0 18px !important;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 8px;
  }
  .gallery-cell {
    position: relative;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    border-radius: 4px;
    background-size: cover;
    background-position: center;
    background-color: #06060a;
    transition: border-color 0.15s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
    overflow: hidden;
  }
  .gallery-cell:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  /* First cell spans both rows and uses a wider aspect ratio */
  .gallery-cell.hero {
    grid-row: span 2;
    aspect-ratio: 16 / 9;
  }
  .gallery-cap {
    position: absolute;
    bottom: 8px; left: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink);
    background: rgba(0, 0, 0, 0.72);
    padding: 3px 6px;
    border-radius: 2px;
  }
  .gallery-cap-n {
    color: var(--accent-2);
    margin-right: 6px;
  }
  @media (max-width: 760px) {
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    .gallery-cell.hero { grid-row: auto; grid-column: span 2; }
  }
</style>
