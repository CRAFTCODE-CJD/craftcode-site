---
/**
 * CraftCode icon — user's authored SVG (hammer + ruler crossed).
 * Inlined via Vite's ?raw import so `currentColor` can inherit the parent
 * `color` CSS property. This lets the logo recolour for any site accent.
 */
import iconSvg from '../assets/logo.svg?raw';

interface Props {
  size?: number;
  class?: string;
}
const { size = 32, class: className = '' } = Astro.props;

// Replace the SVG's fixed `width="500" height="500"` so our `size` prop wins
// (evenodd fill-rule and paths already set on the SVG itself).
const sized = iconSvg
  .replace(/width="\d+"/, `width="${size}"`)
  .replace(/height="\d+"/, `height="${size}"`);
---
<span class={`cc-logo-icon ${className}`} set:html={sized} aria-label="CraftCode" role="img"></span>

<style>
  .cc-logo-icon {
    display: inline-grid;
    place-items: center;
    color: var(--ink);          /* currentColor picked up by SVG fill */
    line-height: 0;
  }
  .cc-logo-icon :global(svg) {
    display: block;
  }
</style>
