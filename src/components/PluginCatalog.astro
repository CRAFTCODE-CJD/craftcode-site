---
/**
 * Compact plugin catalog — single-row table of plugins with factual metadata.
 * Replaces the big screenshot-heavy showcase when space is at a premium.
 * Each row is a ds-card with: accent tag, title, one-line pitch, UE matrix,
 * scope (editor/runtime), version, CTA to FAB + docs.
 */
interface PluginRow {
  slug: string;
  title: string;
  pitch: string;
  accent: string;
  ue: string;              // engine range, e.g. "4.27 · 5.0 – 5.7"
  scope: string;           // "Editor-only" / "Runtime" / "Editor + Runtime"
  version: string;         // semver or descriptor
  fabUrl?: string;
}

const plugins: PluginRow[] = [
  {
    slug: 'sprite-optimizer',
    title: 'Sprite Optimizer',
    pitch: 'Обрезка, упаковка в атласы, Material Instances. Paper2D pipeline в один редактор.',
    accent: '#EC4899',
    ue: '4.27 · 5.0 – 5.7',
    scope: 'Editor-only',
    version: '2.1',
    fabUrl: 'https://www.fab.com/listings/d467cf90-8576-4aa9-b55d-285060a5d1bf',
  },
  {
    slug: 'manualsprite',
    title: 'ManualSprite',
    pitch: 'Ручная геометрия PaperSprite. Static/SkeletalMesh из 2D-арта без 3D-редактора.',
    accent: '#F472B6',
    ue: '5.0 – 5.7',
    scope: 'Editor-only',
    version: '1.x',
  },
  {
    slug: 'mouseinterceptor',
    title: 'MouseInterceptor',
    pitch: 'Глобальный перехват кликов мыши. Двойной клик, Blueprint-делегаты без тика.',
    accent: '#38BDF8',
    ue: '4.27+ · 5.0+',
    scope: 'Runtime',
    version: '1.x',
  },
];
---

<section class="plug-cat" aria-label="Плагины — компактный каталог">
  <div class="plug-cat-head">
    <span class="ds-label">// catalog · 3 plugins · UE 4.27 → 5.7</span>
  </div>

  <div class="plug-cat-list">
    {plugins.map((p) => (
      <article class="plug-row" style={`--row-accent: ${p.accent};`}>
        <div class="plug-row-main">
          <div class="plug-row-title">
            <span class="plug-row-tag">{p.title.toUpperCase()}</span>
            <h3>{p.title}</h3>
          </div>
          <p class="plug-row-pitch">{p.pitch}</p>
        </div>

        <dl class="plug-row-meta">
          <div><dt>UE</dt><dd>{p.ue}</dd></div>
          <div><dt>scope</dt><dd>{p.scope}</dd></div>
          <div><dt>version</dt><dd>v{p.version}</dd></div>
        </dl>

        <div class="plug-row-cta">
          <a class="btn primary" href={`/plugins/${p.slug}/`}>Docs →</a>
          {p.fabUrl && (
            <a class="btn ghost" href={p.fabUrl} target="_blank" rel="noopener">FAB ↗</a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .plug-cat {
    margin: 24px 0 32px;
  }
  .plug-cat-head {
    margin-bottom: 14px;
  }

  .plug-cat-list {
    display: grid;
    gap: 14px;
  }

  .plug-row {
    --row-accent: var(--accent);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 24px;
    align-items: center;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--row-accent);
    border-radius: 4px;
    transition: border-color 0.2s, transform 0.18s, box-shadow 0.2s;
  }
  .plug-row:hover {
    border-color: var(--row-accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 26px -14px var(--row-accent);
  }

  /* ── Column 1: title + pitch ── */
  .plug-row-main {
    min-width: 0;
  }
  .plug-row-title {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
  }
  .plug-row-tag {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    padding: 3px 6px;
    border: 1px solid var(--row-accent);
    color: var(--row-accent);
    text-transform: uppercase;
    letter-spacing: 0;
    white-space: nowrap;
  }
  .plug-row-main h3 {
    margin: 0;
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: var(--ink);
    letter-spacing: 0;
    text-transform: none;
  }
  .plug-row-pitch {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── Column 2: factual metadata (UE / scope / version) ── */
  .plug-row-meta {
    display: grid;
    grid-template-columns: auto auto auto;
    gap: 14px;
    margin: 0;
    padding: 0;
    font-family: 'JetBrains Mono', monospace;
  }
  .plug-row-meta > div {
    display: grid;
    gap: 2px;
    min-width: 0;
  }
  .plug-row-meta dt {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .plug-row-meta dd {
    margin: 0;
    font-size: 13px;
    color: var(--ink);
    white-space: nowrap;
  }

  /* ── Column 3: CTAs ── */
  .plug-row-cta {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Narrow widths: stack columns */
  @media (max-width: 900px) {
    .plug-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .plug-row-meta {
      grid-template-columns: repeat(3, auto);
      justify-content: start;
    }
    .plug-row-cta {
      justify-content: start;
    }
  }

  @media (max-width: 520px) {
    .plug-row-meta {
      grid-template-columns: repeat(2, auto);
    }
  }
</style>
