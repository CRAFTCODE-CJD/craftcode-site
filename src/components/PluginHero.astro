---
import CompanionBot from './CompanionBot.astro';

interface CTA {
  label: string;
  href: string;
  variant?: 'primary' | 'ghost';
  external?: boolean;
}
interface Props {
  kicker?: string;
  title: string;
  version?: string;
  tagline: string;
  image?: string;
  ctas?: CTA[];
  accent?: string;
}
const {
  kicker, title, version, tagline,
  image, ctas = [], accent,
} = Astro.props;
---

<header class="plugin-hero" style={accent ? `--ph-accent: ${accent};` : undefined}>
  <div class="plugin-hero-text">
    {kicker && <div class="plugin-hero-kicker">{kicker}</div>}
    <h1 class="plugin-hero-title">
      {title}
      {version && <span class="plugin-hero-version">{version}</span>}
    </h1>
    <p class="plugin-hero-tag">{tagline}</p>
    
    <div class="mt-8 flex flex-col gap-6">
      {ctas.length > 0 && (
        <div class="plugin-hero-cta">
          {ctas.map((c) => (
            <a
              href={c.href}
              class:list={['plugin-hero-btn glitch-hover', c.variant === 'primary' && 'primary']}
              target={c.external ? '_blank' : undefined}
              rel={c.external ? 'noopener' : undefined}
            >
              {c.variant === 'primary' ? '▸ ' : ''}{c.label}{c.external ? ' ↗' : ''}
            </a>
          ))}
          <div class="flex items-center gap-3 bg-black/40 border border-white/5 py-2 px-4 rounded-lg">
            <CompanionBot bot="code" anim="typing" />
            <div class="flex flex-col">
              <span class="text-[9px] font-mono text-neon-mint opacity-50 uppercase tracking-widest">Bot Status</span>
              <span class="text-[10px] font-mono text-neon-mint animate-pulse uppercase">Typing Docs...</span>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>

  {image && (
    <div class="plugin-hero-media">
      <div class="media-overlay"></div>
      <img src={image} alt={title} loading="eager" />
      <div class="media-badge">PREVIEW_01</div>
    </div>
  )}
</header>

<style>
  .plugin-hero {
    --ph-accent: var(--accent);
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
    margin: 32px 0 64px;
    padding: 48px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(14, 14, 18, 0.95) 0%, rgba(5, 5, 7, 0.95) 100%);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.6);
    position: relative;
    overflow: hidden;
  }

  .plugin-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--ph-accent), transparent);
    opacity: 0.5;
  }

  .plugin-hero-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-2);
    opacity: 0.8;
    margin-bottom: 16px;
  }

  .plugin-hero-title {
    font-family: var(--font-terminal) !important;
    font-size: 72px !important;
    line-height: 0.9 !important;
    margin: 0 !important;
    text-transform: uppercase;
    color: var(--ph-accent) !important;
    text-shadow: 3px 3px 0 var(--bg);
  }

  .plugin-hero-version {
    display: inline-block;
    margin-left: 16px;
    padding: 2px 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ph-accent);
    border: 1px solid var(--ph-accent);
    vertical-align: middle;
  }

  .plugin-hero-tag {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    margin: 24px 0 0;
    max-width: 45ch;
  }

  .plugin-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .plugin-hero-btn {
    padding: 14px 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .plugin-hero-btn:hover {
    border-color: var(--ph-accent);
    color: var(--ph-accent);
    box-shadow: 0 0 20px -5px var(--ph-accent);
    transform: translateY(-2px);
  }

  .plugin-hero-btn.primary {
    background: var(--ph-accent);
    color: var(--bg);
    border-color: var(--ph-accent);
  }

  .plugin-hero-media {
    position: relative;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    transform: perspective(1000px) rotateY(-5deg);
    box-shadow: 20px 20px 40px rgba(0,0,0,0.5);
    transition: transform 0.5s ease;
  }

  .plugin-hero:hover .plugin-hero-media {
    transform: perspective(1000px) rotateY(0deg);
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom right, var(--ph-accent), transparent);
    opacity: 0.1;
    pointer-events: none;
  }

  .plugin-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-badge {
    position: absolute;
    bottom: 12px; left: 12px;
    background: rgba(0,0,0,0.8);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 9px;
    padding: 4px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  @media (max-width: 1000px) {
    .plugin-hero { 
      grid-template-columns: 1fr; 
      padding: 32px;
    }
    .plugin-hero-media { 
      order: -1; 
      transform: none; 
      max-height: 300px;
    }
    .plugin-hero-title { font-size: 52px !important; }
  }
</style>
