---
/**
 * Hero block for per-plugin landing pages. Gives each plugin index a strong
 * visual top — kicker, arcade-styled title, tagline, CTAs, optional hero image.
 *
 * Used at the top of every /plugins/<slug>/ index.mdx. Keep the rest of the
 * page as normal markdown prose — this only replaces the h1 area.
 */
interface CTA {
  label: string;
  href: string;
  variant?: 'primary' | 'ghost';
  external?: boolean;
}
interface Props {
  kicker?: string;         // "// plugin · paper2d"
  title: string;
  version?: string;        // "v2.1"
  tagline: string;         // one-liner pitch
  image?: string;          // optional hero screenshot
  ctas?: CTA[];
  accent?: string;         // hex override; defaults to theme accent
}
const {
  kicker, title, version, tagline,
  image, ctas = [], accent,
} = Astro.props;
---

<header class="plugin-hero" style={accent ? `--ph-accent: ${accent};` : undefined}>
  <div class="plugin-hero-text">
    {kicker && <div class="plugin-hero-kicker">{kicker}</div>}
    <h1 class="plugin-hero-title">
      {title}
      {version && <span class="plugin-hero-version">{version}</span>}
    </h1>
    <p class="plugin-hero-tag">{tagline}</p>
    {ctas.length > 0 && (
      <div class="plugin-hero-cta">
        {ctas.map((c) => (
          <a
            href={c.href}
            class:list={['plugin-hero-btn', c.variant === 'primary' && 'primary']}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener' : undefined}
          >
            {c.variant === 'primary' ? '▸ ' : ''}{c.label}{c.external ? ' ↗' : ''}
          </a>
        ))}
      </div>
    )}
  </div>

  {image && (
    <div class="plugin-hero-media">
      <img src={image} alt={title} loading="eager" />
    </div>
  )}
</header>

<style>
  .plugin-hero {
    --ph-accent: var(--accent);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 32px;
    align-items: center;
    margin: 16px 0 40px;
    padding: 28px 30px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background:
      radial-gradient(ellipse at top right,
        color-mix(in oklab, var(--ph-accent) 14%, transparent),
        transparent 60%),
      var(--surface);
  }
  .plugin-hero-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-2);
    margin-bottom: 12px;
  }
  .plugin-hero-title {
    font-family: 'Press Start 2P', monospace !important;
    font-size: clamp(24px, 4vw, 40px) !important;
    line-height: 1.1 !important;
    margin: 0 !important;
    text-transform: uppercase;
    color: var(--ink) !important;
    text-shadow: 3px 3px 0 var(--accent-2), 6px 6px 0 var(--ph-accent) !important;
  }
  .plugin-hero-version {
    display: inline-block;
    margin-left: 12px;
    padding: 3px 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ph-accent);
    border: 1px solid var(--ph-accent);
    text-shadow: none;
    vertical-align: middle;
  }
  .plugin-hero-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.65;
    color: var(--muted);
    margin: 20px 0 0;
  }
  .plugin-hero-cta {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .plugin-hero-btn {
    padding: 10px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: transform 0.15s, border-color 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .plugin-hero-btn:hover {
    transform: translateY(-1px);
    border-color: var(--ph-accent);
    color: var(--ph-accent);
    box-shadow: 0 6px 20px -10px var(--ph-accent);
  }
  .plugin-hero-btn.primary {
    background: var(--ph-accent);
    color: var(--bg);
    border-color: var(--ph-accent);
  }
  .plugin-hero-btn.primary:hover {
    color: var(--bg);
    box-shadow: 0 6px 22px -6px var(--ph-accent);
  }

  .plugin-hero-media {
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: #06060a;
  }
  .plugin-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .plugin-hero { grid-template-columns: 1fr; }
    .plugin-hero-media { order: -1; max-height: 260px; }
  }
</style>
