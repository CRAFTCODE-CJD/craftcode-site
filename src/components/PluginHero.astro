---
import CompanionBot from './CompanionBot.astro';
interface CTA {
  label: string;
  href: string;
  variant?: 'primary' | 'ghost';
  external?: boolean;
}
interface Props {
  kicker?: string;
  title: string;
  version?: string;
  tagline: string;
  image?: string;
  ctas?: CTA[];
  accent?: string;
  /** Optional i18n keys — when set, text nodes get data-i18n attrs so the
   *  runtime swapper (src/i18n/i18n.ts) can replace them on lang change. */
  i18nKeys?: { title?: string; tagline?: string; kicker?: string };
  /** Optional i18n keys for cta labels — index-aligned with ctas[]. */
  ctaKeys?: (string | undefined)[];
}
const {
  kicker, title, version, tagline,
  image, ctas = [], accent,
  i18nKeys = {},
  ctaKeys = [],
} = Astro.props;
---

<header class="plugin-hero" style={accent ? `--ph-accent: ${accent};` : undefined}>
  <div class="plugin-hero-mascot" aria-hidden="true">
    <CompanionBot bot="code" anim="wave" size={44} />
  </div>
  <div class="plugin-hero-text">
    {kicker && <div class="plugin-hero-kicker" data-i18n={i18nKeys.kicker}>{kicker}</div>}
    <h1 class="plugin-hero-title">
      <span data-i18n={i18nKeys.title}>{title}</span>
      {version && <span class="plugin-hero-version">{version}</span>}
    </h1>
    <p class="plugin-hero-tag" data-i18n={i18nKeys.tagline}>{tagline}</p>

    {ctas.length > 0 && (
      <div class="plugin-hero-cta">
        {ctas.map((c, i) => (
          <a
            href={c.href}
            class:list={['plugin-hero-btn', c.variant === 'primary' && 'primary']}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener' : undefined}
          >
            {c.variant === 'primary' ? '▸ ' : ''}<span data-i18n={ctaKeys[i] ?? undefined}>{c.label}</span>{c.external ? ' ↗' : ''}
          </a>
        ))}
      </div>
    )}
  </div>

  {image ? (
    <div class="plugin-hero-media">
      <div class="media-overlay"></div>
      <picture>
        <source srcset={image.replace(/\.png$/i, '.webp')} type="image/webp" />
        <img src={image} alt={title} loading="eager" />
      </picture>
      <div class="media-badge">PREVIEW_01</div>
    </div>
  ) : null}
</header>

<style>
  .plugin-hero {
    --ph-accent: var(--accent);
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
    margin: 32px 0 64px;
    padding: 48px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(14, 14, 18, 0.95) 0%, rgba(5, 5, 7, 0.95) 100%);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.6);
    position: relative;
    overflow: hidden;
  }

  .plugin-hero-mascot {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    pointer-events: none;
  }

  .plugin-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--ph-accent), transparent);
    opacity: 0.5;
  }

  .plugin-hero-kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-2);
    opacity: 0.8;
    margin-bottom: 16px;
  }

  .plugin-hero-title {
    font-family: 'Press Start 2P', 'Rubik Pixels', monospace !important;
    font-size: clamp(36px, 6vw, 64px) !important;
    /* Press Start 2P glyphs already include vertical padding of ~0.1em.
       line-height ≥ 1.0 keeps a 1-pixel gap between rows when the title
       wraps (e.g. "MOUSE / INTERCEPTOR"). 0.9 made adjacent rows touch. */
    line-height: 1.05 !important;
    margin: 0 !important;
    text-transform: uppercase;
    color: var(--ph-accent) !important;
    text-shadow: 3px 3px 0 var(--bg);
  }

  .plugin-hero-version {
    display: inline-block;
    margin-left: 16px;
    padding: 2px 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ph-accent);
    border: 1px solid var(--ph-accent);
    vertical-align: middle;
  }

  .plugin-hero-tag {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    margin: 24px 0 0;
    max-width: 45ch;
  }

  .plugin-hero-cta {
    margin-top: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .plugin-hero-btn {
    padding: 14px 28px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .plugin-hero-btn:hover {
    border-color: var(--ph-accent);
    color: var(--ph-accent);
    box-shadow: 0 0 20px -5px var(--ph-accent);
    transform: translateY(-2px);
  }

  .plugin-hero-btn.primary {
    background: var(--ph-accent);
    color: var(--bg);
    border-color: var(--ph-accent);
  }

  .plugin-hero-media {
    position: relative;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    transform: perspective(1000px) rotateY(-5deg);
    box-shadow: 20px 20px 40px rgba(0,0,0,0.5);
    transition: transform 0.5s ease;
  }

  .plugin-hero:hover .plugin-hero-media {
    transform: perspective(1000px) rotateY(0deg);
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom right, var(--ph-accent), transparent);
    opacity: 0.1;
    pointer-events: none;
  }

  .plugin-hero-media img,
  .plugin-hero-media iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0;
  }
  .plugin-hero-media--video {
    transform: none;
  }
  .plugin-hero:hover .plugin-hero-media--video {
    transform: none;
  }

  .media-badge {
    position: absolute;
    bottom: 12px; left: 12px;
    background: rgba(0,0,0,0.8);
    color: var(--muted);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    padding: 4px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  @media (max-width: 1000px) {
    .plugin-hero { 
      grid-template-columns: 1fr; 
      padding: 32px;
    }
    .plugin-hero-media { 
      order: -1; 
      transform: none; 
      max-height: 300px;
    }
    .plugin-hero-title { font-size: clamp(28px, 9vw, 44px) !important; }
  }
  @media (max-width: 600px) {
    .plugin-hero-tag {
      font-size: 15px;
      line-height: 1.55;
      margin-top: 18px;
    }
    .plugin-hero-kicker { font-size: 10px; margin-bottom: 10px; }
    .plugin-hero-cta { gap: 10px; margin-top: 18px; }
    .plugin-hero-btn { padding: 11px 18px; font-size: 11px; }
  }
  @media (max-width: 400px) {
    .plugin-hero { padding: 24px 18px; }
    .plugin-hero-title { font-size: clamp(22px, 7.2vw, 30px) !important; }
    .plugin-hero-version {
      display: inline-block;
      margin-left: 8px;
      font-size: 10px;
      padding: 2px 7px;
    }
    .plugin-hero-tag { font-size: 14px; }
    .plugin-hero-btn { padding: 10px 14px; font-size: 10px; }
  }
</style>
