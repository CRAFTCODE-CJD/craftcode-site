---
/**
 * Social / storefront tile for the home page.
 * Accepts a brand slug; the icon/colors come from a small lookup.
 */
interface Props {
  brand: 'fab' | 'youtube' | 'boosty' | 'github' | 'email';
  href: string;
  title: string;
  subtitle?: string;
  cta?: string;
  external?: boolean;
  subtitleI18n?: string;
  ctaI18n?: string;
  titleI18n?: string;
}
const { brand, href, title, subtitle, cta, external = true, subtitleI18n, ctaI18n, titleI18n } = Astro.props as Props;

const BRANDS: Record<Props['brand'], { color: string; label: string }> = {
  fab:     { color: '#0ea5e9', label: 'fab' },
  youtube: { color: '#ef4444', label: 'youtube' },
  boosty:  { color: '#f97316', label: 'boosty' },
  github:  { color: '#a8a8a3', label: 'github' },
  email:   { color: '#10b981', label: 'email' },
};
const b = BRANDS[brand];
---

<a
  class="social-link"
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  style={`--brand: ${b.color}`}
  aria-label={title}
>
  <div class="social-link__head">
    <span class="social-link__kicker">// {b.label}</span>
    {external && <span class="social-link__ext" aria-hidden="true">↗</span>}
  </div>

  <div class="social-link__icon" aria-hidden="true">
    {brand === 'fab' && (
      <svg viewBox="0 0 48 48" width="38" height="38" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="6" y="10" width="36" height="28" rx="3" />
        <path d="M14 18h20M14 24h12M14 30h16" />
        <circle cx="38" cy="14" r="2.5" fill="currentColor" />
      </svg>
    )}
    {brand === 'youtube' && (
      <svg viewBox="0 0 48 48" width="38" height="38" fill="currentColor">
        <path d="M44 14c-.5-2.2-2.2-4-4.4-4.5C35.4 8.5 24 8.5 24 8.5s-11.4 0-15.6 1C6.2 10 4.5 11.8 4 14c-1 4-1 10-1 10s0 6 1 10c.5 2.2 2.2 4 4.4 4.5 4.2 1 15.6 1 15.6 1s11.4 0 15.6-1c2.2-.5 3.9-2.3 4.4-4.5 1-4 1-10 1-10s0-6-1-10zM20 30V18l10 6-10 6z"/>
      </svg>
    )}
    {brand === 'boosty' && (
      <svg viewBox="0 0 48 48" width="38" height="38" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 L10 26 L22 26 L14 42 L38 20 L26 20 L34 6 Z" fill="currentColor"/>
      </svg>
    )}
    {brand === 'github' && (
      <svg viewBox="0 0 48 48" width="38" height="38" fill="currentColor">
        <path d="M24 4C13 4 4 13 4 24c0 8.8 5.7 16.3 13.7 19 1 .2 1.3-.4 1.3-1v-3.5c-5.6 1.2-6.7-2.4-6.7-2.4-.9-2.3-2.2-2.9-2.2-2.9-1.8-1.2.1-1.2.1-1.2 2 .1 3 2 3 2 1.8 3 4.7 2.2 5.8 1.6.2-1.3.7-2.2 1.3-2.7-4.5-.5-9.2-2.2-9.2-10 0-2.2.8-4 2-5.4-.2-.5-.9-2.6.2-5.4 0 0 1.7-.5 5.5 2a19 19 0 0 1 10 0c3.8-2.5 5.5-2 5.5-2 1.1 2.8.4 4.9.2 5.4 1.3 1.4 2 3.2 2 5.4 0 7.8-4.7 9.5-9.2 10 .7.6 1.3 1.8 1.3 3.6V42c0 .6.3 1.2 1.3 1C38.3 40.3 44 32.8 44 24c0-11-9-20-20-20z"/>
      </svg>
    )}
    {brand === 'email' && (
      <svg viewBox="0 0 48 48" width="38" height="38" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="6" y="10" width="36" height="28" rx="2" />
        <path d="m6 12 18 14L42 12" />
      </svg>
    )}
  </div>

  <div class="social-link__body">
    <h3 class="social-link__title" data-i18n={titleI18n ?? undefined}>{title}</h3>
    {subtitle && <p class="social-link__sub" data-i18n={subtitleI18n ?? undefined}>{subtitle}</p>}
  </div>

  {cta && (
    <div class="social-link__foot">
      <span data-i18n={ctaI18n ?? undefined}>{cta}</span>
      <span class="social-link__arrow" aria-hidden="true">→</span>
    </div>
  )}
</a>

<style>
  .social-link {
    --brand: var(--accent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 18px 20px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--ink);
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
    overflow: hidden;
  }
  .social-link::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--brand);
    opacity: 0.4;
    transition: opacity 180ms ease;
  }
  .social-link:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklab, var(--brand) 60%, var(--border));
    box-shadow: 0 20px 40px -24px color-mix(in oklab, var(--brand) 80%, transparent),
                0 0 24px color-mix(in oklab, var(--brand) 25%, transparent);
  }
  .social-link:hover::before { opacity: 1; }

  .social-link__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--faint);
  }
  .social-link__ext {
    color: var(--brand);
    font-size: 14px;
    transition: transform 180ms;
  }
  .social-link:hover .social-link__ext { transform: translate(2px, -2px); }

  .social-link__icon {
    display: grid;
    place-items: center;
    width: 64px; height: 64px;
    margin: 0 auto;
    color: var(--brand);
    background: color-mix(in oklab, var(--brand) 10%, var(--code-bg));
    border: 1px solid color-mix(in oklab, var(--brand) 35%, var(--border));
    border-radius: 8px;
    box-shadow: inset 0 0 12px color-mix(in oklab, var(--brand) 15%, transparent);
    transition: transform 180ms, box-shadow 180ms;
  }
  .social-link:hover .social-link__icon {
    transform: scale(1.06);
    box-shadow:
      inset 0 0 16px color-mix(in oklab, var(--brand) 25%, transparent),
      0 0 24px color-mix(in oklab, var(--brand) 55%, transparent);
  }

  .social-link__body { text-align: center; }
  .social-link__title {
    margin: 0;
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
    line-height: 1;
  }
  .social-link__sub {
    margin: 4px 0 0;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.45;
  }

  .social-link__foot {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    padding-top: 10px;
    border-top: 1px dashed color-mix(in oklab, var(--brand) 25%, var(--border));
  }
  .social-link__arrow { transition: transform 180ms; }
  .social-link:hover .social-link__arrow { transform: translateX(4px); }
</style>
