---
import CompanionBot from './CompanionBot.astro';
/**
 * "Templates — soon" teaser card for the home page.
 */
---

<section class="tmpl-teaser" aria-label="templates teaser" data-i18n-attr="aria-label:templates.teaser.aria">
  <div class="tmpl-grid">
    <div class="tmpl-col">
      <span class="tmpl-kicker" data-i18n="templates.teaser.kicker">// terminal::templates_soon</span>
      <h3 class="tmpl-heading" data-i18n="templates.teaser.heading">Шаблоны проектов и геймплея</h3>
      <p class="tmpl-pitch" data-i18n="templates.teaser.pitch">
        UE-шаблоны с готовой архитектурой: спрайтовый рогалик, top-down
        стрелялка, инвентарь, диалоговая система. Распаковал — работает.
      </p>
      <a class="tmpl-cta" href="/templates/">
        <span data-i18n="templates.teaser.cta">INITIALIZE_TEMPLATES()</span><span class="tmpl-cta__arrow">→</span>
      </a>
    </div>

    <div class="tmpl-status" aria-hidden="true">
      <div class="tmpl-bot-box">
        <CompanionBot bot="craft" anim="typing" size={64} />
      </div>
      <div class="tmpl-status-body">
        <span class="tmpl-status-label" data-i18n="templates.teaser.status.label">sys_status</span>
        <span class="tmpl-status-value" data-i18n="templates.teaser.status.value">прототипы_v0.7</span>
        <div class="tmpl-progress">
          <span class="p p-on"></span>
          <span class="p p-on p-dim"></span>
          <span class="p p-off"></span>
          <span class="p p-off"></span>
          <span class="p p-off"></span>
        </div>
        <div class="tmpl-status-foot">
          <span class="tmpl-status-hint" data-i18n="templates.teaser.status.hint">~5% completed</span>
          <span class="tmpl-status-dot"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tmpl-teaser {
    margin: 40px 0;
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    position: relative;
    overflow: hidden;
  }
  .tmpl-teaser::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 4px; height: 100%;
    background: var(--accent-2);
    opacity: 0.6;
  }
  .tmpl-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .tmpl-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }
  .tmpl-kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-2);
    opacity: 0.75;
  }
  .tmpl-heading {
    margin: 0;
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 32px;
    color: var(--ink);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .tmpl-pitch {
    margin: 0;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 50ch;
  }
  .tmpl-cta {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: color 150ms, border-color 150ms, box-shadow 150ms, transform 150ms;
  }
  .tmpl-cta:hover {
    color: var(--accent-2);
    border-color: var(--accent-2);
    box-shadow: 0 0 18px color-mix(in oklab, var(--accent-2) 45%, transparent);
    transform: translateY(-1px);
  }
  .tmpl-cta__arrow { transition: transform 150ms; }
  .tmpl-cta:hover .tmpl-cta__arrow { transform: translateX(4px); }

  .tmpl-status {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 20px;
    background: color-mix(in oklab, var(--code-bg) 90%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent-2) 20%, var(--border));
    border-radius: var(--radius);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .tmpl-bot-box {
    display: flex;
    justify-content: flex-end;
  }
  .tmpl-status-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-top: 1px solid color-mix(in oklab, var(--accent-2) 20%, var(--border));
    padding-top: 12px;
  }
  .tmpl-status-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .tmpl-status-value {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-2);
    text-shadow: 0 0 12px color-mix(in oklab, var(--accent-2) 60%, transparent);
  }

  .tmpl-progress {
    display: flex;
    gap: 4px;
    margin-top: 4px;
  }
  .p {
    width: 26px; height: 12px;
    border-radius: 2px;
    border: 1px solid color-mix(in oklab, var(--accent-2) 40%, var(--border));
  }
  .p-on {
    background: var(--accent-2);
    box-shadow: 0 0 8px color-mix(in oklab, var(--accent-2) 70%, transparent);
  }
  .p-dim { opacity: 0.45; }
  .p-off { background: transparent; }

  .tmpl-status-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }
  .tmpl-status-hint {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .tmpl-status-dot {
    width: 8px; height: 8px;
    background: var(--accent-2);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-2);
    animation: tmpl-pulse 1.5s ease-in-out infinite;
  }
  @keyframes tmpl-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }

  @media (max-width: 900px) {
    .tmpl-grid { grid-template-columns: 1fr; gap: 24px; }
    .tmpl-teaser { padding: 24px; }
    .tmpl-heading { font-size: 26px; }
  }

  @media (max-width: 600px) {
    .tmpl-teaser { padding: 16px 14px; margin: 28px 0; }
    .tmpl-heading { font-size: 22px; }
    .tmpl-pitch { font-size: 13px; }
    .tmpl-kicker { letter-spacing: 0.1em; overflow-wrap: break-word; word-break: break-all; }
    .tmpl-cta { width: 100%; justify-content: center; padding: 12px 14px; min-height: 44px; }
    .tmpl-status { padding: 14px 12px; }
    .p { width: 20px; }
  }
</style>
