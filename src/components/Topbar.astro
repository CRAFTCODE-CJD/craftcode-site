---
/**
 * Custom Starlight Header override.
 * Terminal/neon styling from the ClaudeDesigner component-topbar mock:
 *  - logo icon (white-inverted with pink+yellow glow) + CRAFTCODE wordmark
 *    split into magenta "CRAFT" and yellow "CODE" with text-shadow glow
 *  - VT323 nav at 18 px with active-underline
 *  - language chip on the right
 */
// Single-locale routing — language is swapped client-side by src/i18n/i18n.ts
// (Phase 5). No /en/ URL branch, no Starlight route data.
const pathname = Astro.url.pathname;

type NavLink = { href: string; labelKey: string; fallback: string; key: string };
const navLinks: NavLink[] = [
  { key: 'home',      href: '/',           labelKey: 'nav.home',      fallback: 'Home' },
  { key: 'plugins',   href: '/plugins/',   labelKey: 'nav.plugins',   fallback: 'Plugins' },
  { key: 'templates', href: '/templates/', labelKey: 'nav.templates', fallback: 'Templates' },
  { key: 'about',     href: '/about/',     labelKey: 'nav.about',     fallback: 'About' },
];
const activeKey =
  pathname === '/'
    ? 'home'
    : navLinks.find(l => l.key !== 'home' && pathname.startsWith(l.href))?.key;
---

<header class="cc-top">
  <div class="cc-top-row">
    <a href="/" class="cc-brand" aria-label="CraftCode — home">
      <img src="/logo/craftcode_icon.svg" alt="" width="52" height="52"
           class="cc-brand-logo" loading="eager" aria-hidden="true" />
      <span class="cc-brand-word">
        <span class="pink">CRAFT</span><span class="yell">CODE</span>
      </span>
    </a>
    <nav class="cc-top-nav" aria-label="Primary">
      {navLinks.map(l => (
        <a
          href={l.href}
          data-i18n={l.labelKey}
          class:list={[{ active: activeKey === l.key }]}
        >{l.fallback}</a>
      ))}
    </nav>
    <div class="cc-top-right">
      <div class="cc-lang" role="group" aria-label="Language">
        <button type="button" class="cc-lang-btn" data-lang="en">EN</button>
        <span class="cc-lang-sep" aria-hidden="true">/</span>
        <button type="button" class="cc-lang-btn" data-lang="ru">RU</button>
      </div>
      <button
        type="button"
        class="cc-burger"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="cc-mobile-nav"
        data-burger
      >
        <span></span><span></span><span></span>
      </button>
      <slot name="search" />
    </div>
  </div>

  <!-- Mobile drawer — hidden on desktop via CSS, toggled by [data-burger]. -->
  <nav id="cc-mobile-nav" class="cc-mobile-nav" aria-label="Mobile" data-mobile-nav hidden>
    {navLinks.map(l => (
      <a
        href={l.href}
        data-i18n={l.labelKey}
        class:list={[{ active: activeKey === l.key }]}
      >{l.fallback}</a>
    ))}
  </nav>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-burger]');
  const nav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  if (btn && nav) {
    const set = (open: boolean) => {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.classList.toggle('is-open', open);
      if (open) nav.removeAttribute('hidden');
      else nav.setAttribute('hidden', '');
      document.body.classList.toggle('cc-nav-open', open);
    };
    btn.addEventListener('click', () => {
      set(btn.getAttribute('aria-expanded') !== 'true');
    });
    // Close when nav link is clicked
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => set(false)));
    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') set(false);
    });
  }
</script>

<style>
  .cc-top {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 56px;
    z-index: 100;
    background: var(--surface);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border));
    box-shadow:
      inset 0 -1px 0 color-mix(in oklab, var(--accent) 30%, transparent),
      0 0 24px color-mix(in oklab, var(--accent) 14%, transparent);
    isolation: isolate;
  }
  .cc-top-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 0 24px;
    height: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ─── Brand (logo + CRAFTCODE wordmark) ─── */
  .cc-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    text-decoration: none;
    transition: transform 0.12s ease-out;
  }
  .cc-brand:hover { transform: translateY(-1px); }

  .cc-brand-logo {
    width: 26px; height: 26px;
    display: block;
    /* Force the logo to pure white regardless of its internal fills,
       then add layered neon glow. */
    filter:
      brightness(0) invert(1)
      drop-shadow(0 0 3px rgba(255, 255, 255, 0.9))
      drop-shadow(0 0 8px color-mix(in oklab, var(--accent) 90%, transparent))
      drop-shadow(0 0 16px color-mix(in oklab, var(--accent-2) 60%, transparent));
  }
  .cc-brand-word {
    font-family: 'Press Start 2P', 'Rubik Pixels', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0;
    line-height: 1;
    text-shadow:
      0 0 6px color-mix(in oklab, var(--accent) 70%, transparent),
      0 0 14px color-mix(in oklab, var(--accent) 40%, transparent);
  }
  .cc-brand-word .pink { color: var(--accent); }
  .cc-brand-word .yell {
    color: var(--accent-2);
    text-shadow:
      0 0 6px color-mix(in oklab, var(--accent-2) 70%, transparent),
      0 0 14px color-mix(in oklab, var(--accent-2) 40%, transparent);
  }

  /* ─── Center nav ─── */
  .cc-top-nav {
    display: flex;
    gap: 20px;
    justify-self: center;
  }
  .cc-top-nav a {
    position: relative;
    /* Set everything directly — Starlight has higher-specificity base rules
       on generic <nav a> selectors that would otherwise override us. */
    font-family: 'VT323', 'Russo One', monospace !important;
    font-size: 18px !important;
    font-weight: 400 !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
    padding-bottom: 6px;
    background: transparent;
    border-radius: 0;
  }
  .cc-top-nav a:hover,
  .cc-top-nav a.active {
    color: var(--ink);
  }
  .cc-top-nav a.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -6px;
    height: 2px;
    background: var(--accent);
  }

  /* ─── Right cluster (lang + search slot) ─── */
  .cc-top-right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }
  /* ─── EN / RU language toggle (terminal-style pill) ─── */
  .cc-lang {
    display: inline-flex;
    align-items: stretch;
    padding: 2px;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius, 4px);
    box-shadow: inset 0 0 8px color-mix(in oklab, var(--accent) 12%, transparent);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .cc-lang-btn {
    background: transparent;
    border: 0;
    color: var(--faint);
    padding: 4px 10px;
    font: inherit;
    cursor: pointer;
    border-radius: 3px;
    transition: color 120ms, background 120ms, text-shadow 120ms;
    position: relative;
  }
  .cc-lang-btn:hover {
    color: var(--ink);
  }
  .cc-lang-btn.active {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 18%, transparent);
    text-shadow: var(--glow-sm);
  }
  .cc-lang-btn.active::before {
    content: '>';
    margin-right: 4px;
    color: var(--accent-3);
    font-weight: 700;
  }
  .cc-lang-sep {
    display: grid;
    place-items: center;
    color: var(--faint);
    padding: 0 1px;
    pointer-events: none;
  }

  /* ─── Burger button (mobile only) ─── */
  .cc-burger {
    display: none;
    width: 36px; height: 36px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius, 4px);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .cc-burger:hover,
  .cc-burger:focus-visible,
  .cc-burger.is-open {
    border-color: var(--accent);
    box-shadow: var(--glow-sm);
  }
  .cc-burger span {
    display: block;
    width: 18px; height: 2px;
    background: var(--ink);
    transition: transform 0.18s ease, opacity 0.18s ease;
    transform-origin: center;
  }
  .cc-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); background: var(--accent); }
  .cc-burger.is-open span:nth-child(2) { opacity: 0; }
  .cc-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); background: var(--accent); }

  /* ─── Mobile drawer (slides down under header) ─── */
  .cc-mobile-nav {
    display: none;
    position: fixed;
    top: 56px; left: 0; right: 0;
    background: var(--surface);
    border-bottom: 1px solid var(--accent);
    box-shadow: var(--glow-md);
    padding: 12px 0;
    z-index: 99;
    flex-direction: column;
  }
  .cc-mobile-nav[hidden] { display: none !important; }
  .cc-mobile-nav a {
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    padding: 12px 24px;
    border-bottom: 1px solid color-mix(in oklab, var(--border) 40%, transparent);
    transition: color 0.12s, background 0.12s;
  }
  .cc-mobile-nav a:last-child { border-bottom: 0; }
  .cc-mobile-nav a:hover,
  .cc-mobile-nav a.active {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 8%, transparent);
  }

  @media (max-width: 760px) {
    .cc-top-nav { display: none; }
    .cc-top-row { grid-template-columns: 1fr auto; }
    .cc-burger { display: inline-flex; }
    .cc-mobile-nav:not([hidden]) { display: flex; }
  }

  /* Prevent body scroll when drawer open on mobile */
  :global(body.cc-nav-open) { overflow: hidden; }
</style>
