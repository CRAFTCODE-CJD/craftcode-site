---
/**
 * Custom Starlight Header override.
 * Terminal/neon styling from the ClaudeDesigner component-topbar mock:
 *  - logo icon (white-inverted with pink+yellow glow) + CRAFTCODE wordmark
 *    split into magenta "CRAFT" and yellow "CODE" with text-shadow glow
 *  - VT323 nav at 18 px with active-underline
 *  - language chip on the right
 */
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import logoSrc from '../assets/logo.png';
import { Image } from 'astro:assets';

// Detect active locale by URL path, not Astro.currentLocale (which returns
// 'ru' for root — doesn't distinguish prefixed vs root pages).
const pathname = Astro.url.pathname;
const isEn = pathname.startsWith('/en/') || pathname === '/en';
const prefix = isEn ? '/en' : '';

type NavLink = { href: string; label: string; external?: boolean; key: string };
const navLinks: NavLink[] = [
  // Explicit HOME link — logo alone isn't always read as "home" by users;
  // a labeled link guarantees one-click access from any deep page.
  { key: 'home',      href: `${prefix}/`,           label: isEn ? 'Home'      : 'Главная' },
  { key: 'plugins',   href: `${prefix}/plugins/`,   label: isEn ? 'Plugins'   : 'Плагины' },
  // "Games" renamed to "Templates" — the section showcases UE project
  // templates that can be sold on FAB / shared through Boosty, not
  // standalone playable games.
  { key: 'templates', href: `${prefix}/templates/`, label: isEn ? 'Templates' : 'Шаблоны' },
  { key: 'about',     href: `${prefix}/about/`,     label: isEn ? 'About'     : 'О нас' },
];
// Home is "active" only when we're EXACTLY on root / /en (not on every page,
// which would trigger because every path startsWith(`${prefix}/`)).
const activeKey =
  (pathname === prefix + '/' || pathname === (prefix || '/') || pathname === '/' || pathname === '/en' || pathname === '/en/')
    ? 'home'
    : navLinks.find(l => l.key !== 'home' && pathname.startsWith(l.href))?.key;
---

<header class="cc-top">
  <div class="cc-top-row">
    <a href={prefix + '/'} class="cc-brand" aria-label="CraftCode — home">
      <Image src={logoSrc} alt="" width={52} height={52}
             class="cc-brand-logo" loading="eager" aria-hidden="true" />
      <span class="cc-brand-word">
        <span class="pink">CRAFT</span><span class="yell">CODE</span>
      </span>
    </a>
    <nav class="cc-top-nav" aria-label="Primary">
      {navLinks.map(l => (
        l.external
          ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
          : <a href={l.href} class:list={[{ active: activeKey === l.key }]}>{l.label}</a>
      ))}
    </nav>
    <div class="cc-top-right">
      <div class="cc-lang"><LanguageSelect {...Astro.props} /></div>
      <slot name="search" />
    </div>
  </div>
</header>

<style>
  .cc-top {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 56px;
    z-index: 100;
    background: var(--surface);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border));
    box-shadow:
      inset 0 -1px 0 color-mix(in oklab, var(--accent) 30%, transparent),
      0 0 24px color-mix(in oklab, var(--accent) 14%, transparent);
    isolation: isolate;
  }
  .cc-top-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 0 24px;
    height: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ─── Brand (logo + CRAFTCODE wordmark) ─── */
  .cc-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    text-decoration: none;
    transition: transform 0.12s ease-out;
  }
  .cc-brand:hover { transform: translateY(-1px); }

  .cc-brand-logo {
    width: 26px; height: 26px;
    display: block;
    /* Force the logo to pure white regardless of its internal fills,
       then add layered neon glow. */
    filter:
      brightness(0) invert(1)
      drop-shadow(0 0 3px rgba(255, 255, 255, 0.9))
      drop-shadow(0 0 8px color-mix(in oklab, var(--accent) 90%, transparent))
      drop-shadow(0 0 16px color-mix(in oklab, var(--accent-2) 60%, transparent));
  }
  .cc-brand-word {
    font-family: 'Press Start 2P', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0;
    line-height: 1;
    text-shadow:
      0 0 6px color-mix(in oklab, var(--accent) 70%, transparent),
      0 0 14px color-mix(in oklab, var(--accent) 40%, transparent);
  }
  .cc-brand-word .pink { color: var(--accent); }
  .cc-brand-word .yell {
    color: var(--accent-2);
    text-shadow:
      0 0 6px color-mix(in oklab, var(--accent-2) 70%, transparent),
      0 0 14px color-mix(in oklab, var(--accent-2) 40%, transparent);
  }

  /* ─── Center nav ─── */
  .cc-top-nav {
    display: flex;
    gap: 20px;
    justify-self: center;
  }
  .cc-top-nav a {
    position: relative;
    /* Set everything directly — Starlight has higher-specificity base rules
       on generic <nav a> selectors that would otherwise override us. */
    font-family: 'VT323', monospace !important;
    font-size: 18px !important;
    font-weight: 400 !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
    padding-bottom: 6px;
    background: transparent;
    border-radius: 0;
  }
  .cc-top-nav a:hover,
  .cc-top-nav a.active {
    color: var(--ink);
  }
  .cc-top-nav a.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -6px;
    height: 2px;
    background: var(--accent);
  }

  /* ─── Right cluster (lang + search slot) ─── */
  .cc-top-right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }
  .cc-lang :global(starlight-lang-select select) {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    /* Wider right padding so full locale name ("Русский", "English")
       fits without being truncated by the caret. */
    padding: 4px 34px 4px 30px;
    min-width: 120px;
    font: inherit;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--radius, 4px);
    cursor: pointer;
    /* Prevent "…" ellipsis inside the native select when text is long. */
    text-overflow: initial;
    overflow: visible;
  }
  .cc-lang :global(starlight-lang-select select:hover) {
    color: var(--accent);
    border-color: var(--accent);
  }
  .cc-lang :global(starlight-lang-select .label-icon),
  .cc-lang :global(starlight-lang-select .caret) {
    color: var(--muted);
  }
  .cc-lang :global(starlight-lang-select:hover .label-icon),
  .cc-lang :global(starlight-lang-select:hover .caret) {
    color: var(--accent);
  }

  @media (max-width: 760px) {
    .cc-top-nav { display: none; }
    .cc-top-row { grid-template-columns: 1fr auto; }
  }
</style>
