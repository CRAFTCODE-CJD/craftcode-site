---
/**
 * YouTube channel + latest-video card for the home page.
 *
 * Shows (left) a thumbnail + play-overlay linking to the current video,
 * (right) a short pitch + "latest: <title>" line + "open channel" CTA.
 *
 * Thumbnail URL pattern (no API key): https://img.youtube.com/vi/<id>/maxresdefault.jpg
 *    (falls back to /hqdefault.jpg if maxres doesn't exist)
 *
 * Update the `latest` prop manually when a new video ships — a full
 * YouTube-API integration would add a network dependency we don't need
 * for a single visible tile.
 */
import AsciiLogo from './AsciiLogo.astro';

interface Props {
  /** Channel handle for the "open channel" link. */
  channelUrl?: string;
  /** Displayed channel name/handle. */
  channelName?: string;
  /** Optional latest-video to feature. */
  latest?: { id: string; title: string };
}

const {
  channelUrl = 'https://www.youtube.com/@jonathandeveloper6723',
  channelName = '@jonathandeveloper6723',
  latest,
} = Astro.props;

// If no specific latest video is provided, we show a generic channel tile
// (no thumbnail, just brand + channel name). Author fills `latest` on new uploads.
const thumbUrl = latest
  ? `https://img.youtube.com/vi/${latest.id}/hqdefault.jpg`
  : null;
const watchUrl = latest
  ? `https://www.youtube.com/watch?v=${latest.id}`
  : channelUrl;
---

<section class="yt-card" aria-label="YouTube">
  <a class="yt-link" href={watchUrl} target="_blank" rel="noopener"
     aria-label={latest ? `Смотреть: ${latest.title}` : 'Открыть YouTube-канал'}>
    <div class="yt-header">
       <span class="ds-label">// youtube</span>
    </div>
    <div class="yt-thumb-container">
      <AsciiLogo type="youtube" />
      <div class="yt-play" aria-hidden="true">
        <span>WATCH</span>
      </div>
    </div>
    <div class="yt-footer">
       <span class="yt-latest-label">Latest Video <span>→</span></span>
    </div>
  </a>
</section>

<style>
  .yt-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .yt-card:hover {
    transform: translateY(-2px);
    border-color: #ff0000;
    box-shadow: 0 0 20px -10px rgba(255, 0, 0, 0.3);
  }
  .yt-link {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 12px 16px;
  }
  .yt-header {
    margin-bottom: 8px;
  }
  .yt-thumb-container {
    position: relative;
    height: 70px;
    background: color-mix(in oklab, #ff0000 3%, #000);
    border-radius: 4px;
    overflow: hidden;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in oklab, #ff0000 10%, transparent);
    transition: background 0.2s;
  }
  .yt-card:hover .yt-thumb-container {
    background: color-mix(in oklab, #ff0000 8%, #000);
  }
  
  .yt-neo-icon {
    color: #ff0000;
    filter: drop-shadow(0 0 8px rgba(255, 0, 0, 0.6));
    transition: transform 0.2s, filter 0.2s;
  }
  .yt-card:hover .yt-neo-icon {
    transform: scale(1.1);
    filter: drop-shadow(0 0 12px rgba(255, 0, 0, 0.9));
  }

  .yt-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: rgba(0,0,0,0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 0.1em;
  }
  .yt-link:hover .yt-play {
    opacity: 1;
  }
  .yt-footer {
     margin-top: 10px;
     display: flex;
     justify-content: flex-end;
  }
  .yt-latest-label {
     font-family: 'JetBrains Mono', monospace;
     font-size: 11px;
     color: rgba(255, 0, 0, 0.8);
     text-transform: uppercase;
     letter-spacing: 0.05em;
     transition: color 0.2s;
  }
  .yt-card:hover .yt-latest-label {
    color: #ff0000;
  }
  .yt-latest-label span {
    display: inline-block;
    transition: transform 0.2s;
  }
  .yt-card:hover .yt-latest-label span {
    transform: translateX(4px);
  }
</style>
