---
interface Props { title: string; icon?: string; titleId?: string; }
const { title, titleId } = Astro.props as Props;
---

<div class="mdx-card neon-frame">
  <h3 class="mdx-card__title" data-i18n={titleId ?? undefined}>{title}</h3>
  <div class="mdx-card__body"><slot /></div>
</div>

<style>
  /* Flex column + min-height keeps every card in a <CardGrid> at a
     consistent vertical footprint — so grid rows align even when one
     card has one line of body text and its neighbour has three.
     The body flex-grows into the remaining space. */
  .mdx-card {
    padding: 14px 16px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    min-height: 120px;
    height: 100%;
  }
  .mdx-card__title {
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 20px;
    color: var(--accent-2);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 6px;
  }
  .mdx-card__body {
    color: var(--muted);
    line-height: 1.55;
    font-size: 14px;
    flex: 1 1 auto;
  }
  .mdx-card__body :global(p) { margin: 0; }
  .mdx-card__body :global(strong) { color: var(--ink); }
</style>
