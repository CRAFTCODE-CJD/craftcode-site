---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  /** When true and no `caption` is set, render `alt` as the caption. Opt-in
   *  so existing usages stay unchanged; MDX authors enable per-image. */
  autoCaption?: boolean;
  width?: number;
  height?: number;
}
const { src, alt = '', caption, autoCaption = false, width, height } = Astro.props as Props;
// Effective caption: explicit wins; else fall back to alt when autoCaption is on.
const effectiveCaption = caption ?? (autoCaption && alt ? alt : undefined);
---

<figure class="mdx-image">
  <button
    type="button"
    class="mdx-image__trigger"
    data-lightbox-src={src}
    data-lightbox-alt={alt || effectiveCaption || ''}
    aria-label="Открыть увеличенное изображение"
  >
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="mdx-image__img"
    />
    <span class="mdx-image__zoom" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3-3M11 8v6M8 11h6"></path>
      </svg>
    </span>
  </button>
  {effectiveCaption && <figcaption class="mdx-image__caption">// {effectiveCaption}</figcaption>}
</figure>

<style>
  .mdx-image {
    margin: 20px 0;
    padding: 0;
  }
  .mdx-image__trigger {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: zoom-in;
  }
  .mdx-image__img {
    display: block;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: box-shadow 160ms ease, transform 160ms ease;
  }
  .mdx-image__trigger:hover .mdx-image__img,
  .mdx-image__trigger:focus-visible .mdx-image__img {
    box-shadow: var(--glow-md);
    transform: translateY(-1px);
  }
  .mdx-image__zoom {
    position: absolute;
    top: 8px; right: 8px;
    width: 28px; height: 28px;
    display: grid;
    place-items: center;
    background: color-mix(in oklab, var(--bg) 70%, transparent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    color: var(--accent);
    opacity: 0;
    transition: opacity 160ms ease;
    pointer-events: none;
  }
  .mdx-image__trigger:hover .mdx-image__zoom,
  .mdx-image__trigger:focus-visible .mdx-image__zoom {
    opacity: 1;
  }
  .mdx-image__caption {
    margin-top: 6px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--muted);
  }
</style>
