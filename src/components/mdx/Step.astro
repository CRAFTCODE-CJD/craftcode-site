---
interface Props { title?: string; }
const { title } = Astro.props as Props;
---

<li class="mdx-step">
  {title && <h4 class="mdx-step__title">{title}</h4>}
  <div class="mdx-step__body"><slot /></div>
</li>

<style>
  .mdx-step__title {
    font-family: 'VT323', 'Roboto Mono', monospace;
    font-size: 20px;
    color: var(--ink);
    margin: 0 0 4px;
    text-transform: uppercase;
  }
  .mdx-step__body :global(p) { margin: 4px 0; color: var(--muted); }
</style>
