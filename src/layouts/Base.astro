---
/**
 * Base layout — applied to every route. Owns:
 *   · <head> (meta, fonts, favicons, style bundle)
 *   · Topbar
 *   · <Companions /> (site-wide bots + terminal overlay)
 *   · <main> slot
 *   · scanlines overlay
 *
 * i18n: no per-locale URL — Topbar toggles `lang` on <html> via localStorage;
 * src/i18n/i18n.ts (Phase 5) hydrates all `data-i18n="key"` nodes.
 */
import '~/styles/themes.css';
import '~/styles/terminal.css';
import '~/styles/companions.css';
import '~/styles/site.css';

import Topbar from '~/components/Topbar.astro';
import Companions from '~/components/Companions.astro';
import BootSplash from '~/components/BootSplash.astro';
import Lightbox from '~/components/Lightbox.astro';
import SiteFooter from '~/components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'ru';
  /** OG image absolute URL. */
  image?: string;
  /** Route-scoped CSS class for layout tweaks (e.g. 'is-home', 'is-plugin'). */
  bodyClass?: string;
  /** Which i18n scopes the page wants. Defaults to ['common']; pages with
   *  rich plugin docs add 'plugin', the home page (KAPLAY) adds 'dialogue'. */
  i18nScopes?: Array<'common' | 'plugin' | 'dialogue'>;
}

const {
  title,
  description = 'CraftCode — tools and toys for game developers.',
  lang = 'ru',
  image,
  bodyClass,
  i18nScopes = ['common'],
} = Astro.props as Props;

const siteTitle = title === 'CRAFTCODE' ? title : `${title} // CRAFTCODE`;
const ogImage = image ?? '/logo/craftcode_wide.png';
const scopesAttr = i18nScopes.join(',');
---

<!doctype html>
<html lang={lang} data-theme="cyberpunk" data-i18n-scopes={scopesAttr}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <!-- Preload critical fonts to eliminate FOIT for hero/body text. -->
    <link rel="preload" as="font" type="font/woff2"
      href="https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiA.woff2"
      crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2"
      href="https://fonts.gstatic.com/s/pressstart2p/v16/e3t4euO8T-267oIAQAu6jDQyK3nVivM.woff2"
      crossorigin="anonymous" />
    <!-- Font stack (3 families, mobile-friendly):
         · Press Start 2P            — pixel/arcade display (logo + headings, latin only).
         · Inter                     — body text (Latin + Cyrillic, weights trimmed to 400/600/800).
         · JetBrains Mono            — terminal/code/UI (Latin only — Cyrillic glyphs unused
                                       in mono code blocks; saves a unicode-range subset request).
         Async-load via media=print swap to keep the CSS off the critical
         render path; once it resolves we promote it back to media=all. The
         <noscript> branch covers JS-disabled fallbacks. -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@400;600&family=Press+Start+2P&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@400;600&family=Press+Start+2P&display=swap"
      />
    </noscript>

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body class:list={[bodyClass]}>
    <BootSplash />
    <Topbar />

    <main class="cc-main">
      <slot />
    </main>

    <SiteFooter />

    <Companions />
    <Lightbox />

    <!-- Client-side i18n + lang toggle wiring. Imported here so every page
         gets the behavior without having to opt in. -->
    <script>
      import { initI18n } from '~/i18n/i18n';
      initI18n();
    </script>
  </body>
</html>
