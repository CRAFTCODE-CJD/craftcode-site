---
import Base from '~/layouts/Base.astro';
import BootToPlayground from '~/components/BootToPlayground.astro';
import SocialLink from '~/components/SocialLink.astro';
import TemplatesTeaser from '~/components/TemplatesTeaser.astro';
import DonateSection from '~/components/DonateSection.astro';
import IdleEasterEgg from '~/components/IdleEasterEgg.astro';
import LatestReleases from '~/components/LatestReleases.astro';
import SystemLog from '~/components/SystemLog.astro';
---

<Base title="CRAFTCODE" description="A workshop of two robots — plugins and games for Unreal Engine." bodyClass="is-home">
  <BootToPlayground />

  <section class="home-wrap">
    <SystemLog />
    <LatestReleases />

    <section class="home-social" aria-label="CRAFTCODE channels" data-i18n-attr="aria-label:home.social.aria">
      <header class="home-social__head">
        <p class="home-social__kicker" data-i18n="home.social.kicker">// channels</p>
        <h2 class="home-social__title" data-i18n="home.social.title">Где меня найти</h2>
      </header>
      <div class="home-social__grid">
        <SocialLink
          brand="fab"
          href="https://www.fab.com/sellers/CRAFTCODE"
          title="FAB Marketplace"
          subtitle="Плагины и ассеты для Unreal Engine"
          subtitleI18n="home.social.fab.sub"
          cta="Marketplace"
          ctaI18n="home.social.fab.cta"
        />
        <SocialLink
          brand="youtube"
          href="https://www.youtube.com/@jonathandeveloper6723"
          title="YouTube"
          subtitle="Devlog, разборы и футажи проделанной работы"
          subtitleI18n="home.social.yt.sub"
          cta="Latest video"
          ctaI18n="home.social.yt.cta"
        />
        <SocialLink
          brand="boosty"
          href="https://boosty.to/channel-jonathan-developer"
          title="Boosty"
          subtitle="Эксклюзивный контент для подписчиков"
          subtitleI18n="home.social.boosty.sub"
          cta="Subscribe"
          ctaI18n="home.social.boosty.cta"
        />
      </div>
    </section>

    <DonateSection />
    <TemplatesTeaser />
  </section>

  <IdleEasterEgg />
</Base>

<style>
  .home-wrap {
    max-width: 1080px;
    margin-inline: auto;
    padding: 0 16px 48px;
  }

  /* Uniform rhythm between top-level home sections. Using :global()
     because SystemLog / LatestReleases / DonateSection / TemplatesTeaser
     are child components with their own root elements. The `> *` selector
     would only catch immediate children of .home-wrap (exactly those
     components), and a consistent top-margin beats each component
     inventing its own padding. */
  .home-wrap > :global(* + *) { margin-top: 56px; }
  @media (max-width: 700px) {
    .home-wrap > :global(* + *) { margin-top: 40px; }
  }

  .home-social { margin: 0; }
  .home-social__head {
    text-align: center;
    margin-bottom: 24px;
  }
  .home-social__kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: var(--muted);
    margin: 0 0 6px;
  }
  .home-social__title {
    font-family: 'VT323', 'Russo One', monospace;
    font-size: clamp(26px, 4vw, 34px);
    color: var(--accent-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    text-shadow: 0 0 12px color-mix(in oklab, var(--accent-2) 45%, transparent);
  }

  .home-social__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
  }

  /* ASCII-corner decoration for the "где меня найти" block */
  .home-social {
    position: relative;
    padding: 20px 8px 8px;
  }
  .home-social::before,
  .home-social::after {
    content: '';
    position: absolute;
    width: 28px; height: 28px;
    border-color: color-mix(in oklab, var(--accent) 45%, transparent);
    opacity: 0.55;
    pointer-events: none;
  }
  .home-social::before {
    top: 0; left: -4px;
    border-top: 2px solid; border-left: 2px solid;
  }
  .home-social::after {
    bottom: 0; right: -4px;
    border-bottom: 2px solid; border-right: 2px solid;
  }

  /* Release-card hover — lift + accent outline glow. Previous version
     used a clip-path glitch keyframe which could freeze cards in a
     clipped state when :hover ended mid-animation (black horizontal
     bands). Reverted to a clean transition-only effect: the hover
     still reads as reactive, but can't leave broken visuals behind. */
  :global(.release-card) {
    transition:
      transform 180ms ease,
      box-shadow 220ms ease,
      border-color 180ms ease;
    will-change: transform;
  }
  :global(.release-card:hover) {
    transform: translateY(-3px);
    border-color: color-mix(in oklab, var(--accent) 70%, var(--border));
    box-shadow:
      0 0 0 1px color-mix(in oklab, var(--accent) 50%, transparent),
      0 12px 28px -12px color-mix(in oklab, var(--accent) 55%, transparent),
      inset 0 0 24px color-mix(in oklab, var(--accent) 10%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.release-card:hover) { transform: none; }
  }
</style>
