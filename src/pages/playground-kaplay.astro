---
/**
 * Opt-in preview of the KAPLAY-backed playground.
 *
 * Lives at /playground-kaplay so developers can exercise the WebGL
 * runtime (sprites, physics, drag/throw, bubbles, wander) without
 * touching the home page — which still mounts the legacy DOM engine.
 *
 * Swap this page to the home page once the KAPLAY surface reaches
 * feature parity with engine.legacy.js, then delete BootToPlayground.astro.
 */
import Base from '~/layouts/Base.astro';
import KaplayPlayground from '~/components/KaplayPlayground.astro';
---

<Base title="KAPLAY playground — CRAFTCODE" description="WebGL playground preview" bodyClass="is-home">
  <KaplayPlayground />
  <section style="max-width: 1080px; margin: 24px auto; padding: 0 16px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--muted);">
    <p>// preview: KAPLAY runtime — physics, sprites, drag/throw, wander. Bubbles bridge to dialogues.data.js via kaplay.dialogue-bridge.ts.</p>
    <p>// open devtools → <code>window.__kaplayBots</code> / <code>window.__dialogue</code> to inspect.</p>
  </section>
</Base>
