---
/**
 * Dynamic plugin pages — picks up every MDX/MD under
 * src/content/docs/plugins/** and renders it with:
 *   · hero or simple header
 *   · breadcrumbs (Plugins → <Plugin> → <Page>)
 *   · sidebar with siblings of the current plugin
 *   · MDX content with our custom components
 *
 * URL: /plugins/<slug>/ (e.g. /plugins/sprite-optimizer/reference/)
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '~/layouts/Base.astro';
import PluginHero from '~/components/PluginHero.astro';
import CompanionBot from '~/components/CompanionBot.astro';
import * as mdxComponents from '~/components/mdx';

type DocEntry = CollectionEntry<'docs'>;

interface SidebarLink {
  href: string;
  title: string;
  order: number;
  active: boolean;
  isIndex: boolean;
  subgroup?: string;
}

export async function getStaticPaths() {
  const entries = await getCollection('docs', ({ id }: DocEntry) => id.startsWith('plugins/'));
  return entries.map((entry: DocEntry) => {
    const rawSlug = entry.id.replace(/^plugins\//, '');
    // Top-level plugin slug ("sprite-optimizer"), used to collect siblings.
    const pluginSlug = rawSlug.split('/')[0];
    const siblings = entries
      .filter((e: DocEntry) => {
        const id = e.id.replace(/^plugins\//, '');
        return id === pluginSlug || id.startsWith(`${pluginSlug}/`);
      })
      .map((e: DocEntry) => {
        const id = e.id.replace(/^plugins\//, '');
        const parts = id.split('/');
        const isIndex = parts.length === 1;
        const href = `/plugins/${id}/`;
        const subgroup = parts.length > 2 ? parts[1] : undefined;
        return {
          href,
          title: e.data.title,
          order: e.data.order ?? 999,
          active: e.id === entry.id,
          isIndex,
          subgroup,
        } satisfies SidebarLink;
      })
      .sort((a: SidebarLink, b: SidebarLink) => a.order - b.order);

    return {
      params: { slug: rawSlug || undefined },
      props: { entry, pluginSlug, siblings },
    };
  });
}

interface Props {
  entry: DocEntry;
  pluginSlug: string;
  siblings: SidebarLink[];
}
const { entry, pluginSlug, siblings } = Astro.props as Props;
const { Content, headings } = await render(entry);
const data = entry.data;

// Current page's plugin-index (for breadcrumb middle segment).
const pluginIndex = siblings.find((s) => s.isIndex);
const isPluginIndex = entry.id === `plugins/${pluginSlug}`;
---

<Base title={data.title} description={data.description} image={data.image}>
  <article class="plugin-page" style={data.accent ? `--accent: ${data.accent}` : undefined}>
    <!-- Breadcrumbs — always visible, helps orientation. -->
    <nav class="plugin-crumbs" aria-label="Breadcrumbs">
      <a href="/plugins/">Plugins</a>
      {pluginIndex && !isPluginIndex && (
        <>
          <span class="sep" aria-hidden="true">/</span>
          <a href={pluginIndex.href}>{pluginIndex.title}</a>
        </>
      )}
      {!isPluginIndex && (
        <>
          <span class="sep" aria-hidden="true">/</span>
          <span class="current">{data.title}</span>
        </>
      )}
      {isPluginIndex && (
        <>
          <span class="sep" aria-hidden="true">/</span>
          <span class="current">{data.title}</span>
        </>
      )}
    </nav>

    {data.plugin_page ? (
      <>
        <PluginHero
          kicker={data.kicker}
          title={data.title}
          version={data.version}
          tagline={data.tagline ?? ''}
          image={data.image}
          accent={data.accent}
          ctas={data.ctas}
        />

        {data.stats && data.stats.stats.length > 0 && (
          <section class="plugin-stats" aria-label={data.stats.title}>
            <header class="plugin-section__head">
              <p class="plugin-section__kicker">// stats</p>
              <h2 class="plugin-section__title">{data.stats.title}</h2>
            </header>
            <div class="plugin-stats__grid">
              {data.stats.stats.map((s) => (
                <div class="stat-card">
                  <p class="stat-card__label">{s.label}</p>
                  <p class="stat-card__value">{s.value}</p>
                  {s.delta && <p class="stat-card__delta">{s.delta}</p>}
                </div>
              ))}
            </div>
          </section>
        )}

        {data.pipeline && data.pipeline.steps.length > 0 && (
          <section class="plugin-pipeline" aria-label={data.pipeline.title}>
            <header class="plugin-section__head">
              <p class="plugin-section__kicker">// pipeline</p>
              <h2 class="plugin-section__title">{data.pipeline.title}</h2>
            </header>
            <ol class="plugin-pipeline__list">
              {data.pipeline.steps.map((s) => (
                <li class="pipeline-step">
                  <span class="pipeline-step__n">{s.n}</span>
                  <h3 class="pipeline-step__title">{s.title}</h3>
                  <p class="pipeline-step__text">{s.text}</p>
                </li>
              ))}
            </ol>
          </section>
        )}
      </>
    ) : (
      <header class="plugin-page__head">
        {data.kicker && <p class="plugin-page__kicker">{data.kicker}</p>}
        <h1 class="plugin-page__title">{data.title}</h1>
        {data.tagline && <p class="plugin-page__tagline">{data.tagline}</p>}
      </header>
    )}

    <div class="plugin-page__layout">
      {siblings.length > 1 && (
        <aside class="plugin-sidebar" aria-label="Plugin pages">
          <p class="plugin-sidebar__kicker">// {pluginSlug}</p>
          <div class="plugin-sidebar__bot" aria-hidden="true">
            <CompanionBot bot="code" anim="typing" size={40} />
          </div>
          <ul>
            {siblings.map((s) => (
              <li class:list={[{ active: s.active, nested: !!s.subgroup }]}>
                {s.subgroup && <span class="plugin-sidebar__group">/{s.subgroup}</span>}
                <a href={s.href} aria-current={s.active ? 'page' : undefined}>{s.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <div class="plugin-page__body">
        <Content components={mdxComponents} />

        {data.plugin_page && data.gallery && data.gallery.shots.length > 0 && (
          <section class="plugin-gallery" aria-label={data.gallery.title}>
            <header class="plugin-section__head">
              <p class="plugin-section__kicker">// gallery</p>
              <h2 class="plugin-section__title">{data.gallery.title}</h2>
            </header>
            <div class="plugin-gallery__grid">
              {data.gallery.shots.map((shot) => (
                <figure class="gallery-shot">
                  <img src={shot.src} alt={shot.caption} loading="lazy" />
                  <figcaption>
                    {shot.n && <span class="gallery-shot__n">{shot.n}</span>}
                    <span class="gallery-shot__caption">{shot.caption}</span>
                  </figcaption>
                </figure>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </article>
</Base>

<style>
  .plugin-page { max-width: 1200px; margin-inline: auto; padding: 24px 16px 64px; }

  /* ─── Breadcrumbs ─── */
  .plugin-crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 18px;
    padding-bottom: 8px;
    border-bottom: 1px dashed var(--border);
  }
  .plugin-crumbs a {
    color: var(--muted);
    text-decoration: none;
    transition: color 120ms;
  }
  .plugin-crumbs a:hover { color: var(--accent-3); }
  .plugin-crumbs .sep { color: var(--faint); }
  .plugin-crumbs .current { color: var(--accent); text-shadow: var(--glow-sm); }

  /* ─── Layout: sidebar + content ─── */
  .plugin-page__layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .plugin-page__layout { grid-template-columns: 1fr; }
  }

  /* ─── Sidebar ─── */
  .plugin-sidebar {
    position: sticky;
    top: 72px;
    padding: 14px 14px 14px 0;
    border-right: 1px dashed var(--border);
  }
  @media (max-width: 900px) {
    .plugin-sidebar {
      position: static;
      border-right: 0;
      border-bottom: 1px dashed var(--border);
      padding: 0 0 14px;
      margin-bottom: 14px;
    }
  }
  .plugin-sidebar__kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--muted);
    margin: 0 0 10px;
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }
  .plugin-sidebar__bot {
    display: flex;
    justify-content: flex-start;
    margin: 0 0 10px;
    opacity: 0.85;
  }
  .plugin-sidebar ul { list-style: none; margin: 0; padding: 0; }
  .plugin-sidebar li { margin: 2px 0; }
  .plugin-sidebar li.nested { padding-left: 12px; border-left: 1px solid var(--border); margin-left: 4px; }
  .plugin-sidebar__group {
    display: block;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--faint);
    padding: 4px 0 2px;
    text-transform: lowercase;
  }
  .plugin-sidebar a {
    display: block;
    padding: 6px 10px;
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 16px;
    color: var(--muted);
    text-decoration: none;
    border-radius: 3px;
    transition: color 120ms, background 120ms;
  }
  .plugin-sidebar a:hover { color: var(--ink); background: color-mix(in oklab, var(--accent) 6%, transparent); }
  .plugin-sidebar li.active a {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    text-shadow: var(--glow-sm);
  }

  /* ─── Content body ─── */
  .plugin-page__head { margin: 8px 0 28px; }
  .plugin-page__kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--muted);
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .plugin-page__title {
    font-family: 'Press Start 2P', 'Rubik Pixels', monospace;
    font-size: clamp(20px, 4vw, 32px);
    text-shadow: 3px 3px 0 var(--accent-2), 6px 6px 0 var(--accent);
    margin: 0 0 10px;
  }
  .plugin-page__tagline { color: var(--muted); max-width: 60ch; }
  .plugin-page__body :global(h2) {
    font-family: 'VT323', 'Russo One', monospace;
    color: var(--accent-2);
    text-transform: uppercase;
    font-size: 28px;
    letter-spacing: 0.02em;
    margin: 32px 0 10px;
  }
  .plugin-page__body :global(h3) {
    font-family: 'VT323', 'Russo One', monospace;
    color: var(--ink);
    font-size: 22px;
    text-transform: uppercase;
    margin: 24px 0 8px;
  }
  .plugin-page__body :global(a) { color: var(--accent-3); }
  .plugin-page__body :global(code) {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.92em;
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--accent);
  }
  .plugin-page__body :global(pre) {
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 14px 16px;
    border-radius: var(--radius);
    overflow-x: auto;
    font-size: 13px;
  }
  .plugin-page__body :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
    color: inherit;
  }

  /* Plain-markdown images in MDX: constrain size + centre so they don't
     dominate the column. Click opens the global Lightbox (delegated
     handler lives in src/components/Lightbox.astro). */
  .plugin-page__body :global(img) {
    max-width: 680px;
    width: 100%;
    height: auto;
    display: block;
    margin: 20px auto;
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: zoom-in;
    transition: box-shadow 160ms ease, transform 160ms ease;
  }
  .plugin-page__body :global(img:hover) {
    box-shadow: var(--glow-md);
    transform: translateY(-1px);
  }

  /* Plain-markdown tables: explicit frame + background so reference pages
     read like a datasheet, not bare rows. */
  .plugin-page__body :global(table) {
    width: 100%;
    background: color-mix(in oklab, var(--surface) 96%, black);
    border: 1px solid color-mix(in oklab, var(--accent) 30%, var(--grid));
    border-radius: 6px;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    margin: 18px 0;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--accent) 8%, transparent);
  }
  .plugin-page__body :global(table thead th) {
    background: color-mix(in oklab, var(--accent) 18%, var(--grid));
    color: var(--accent-2);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 10px 14px;
    text-align: left;
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent-2) 40%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, var(--grid));
  }
  .plugin-page__body :global(table td) {
    padding: 10px 14px;
    border-bottom: 1px solid color-mix(in oklab, var(--grid) 80%, transparent);
    color: var(--muted);
    vertical-align: top;
  }
  .plugin-page__body :global(table tr:last-child td) { border-bottom: 0; }
  .plugin-page__body :global(table tr:hover td) {
    background: color-mix(in oklab, var(--accent) 6%, transparent);
    color: var(--ink);
  }
  .plugin-page__body :global(table td code),
  .plugin-page__body :global(table th code) {
    font-size: 0.9em;
    padding: 1px 5px;
  }

  /* Narrow viewports: let tables scroll horizontally inside their own
     column instead of pushing the whole page to 360px+. `display: block`
     on <table> lets overflow-x kick in without needing a wrapper <div>
     (which MDX-rendered markdown doesn't provide). -webkit-overflow-
     scrolling keeps momentum scroll on iOS. */
  @media (max-width: 600px) {
    .plugin-page__body :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      max-width: 100%;
      white-space: nowrap;
    }
    .plugin-page__body :global(table thead th),
    .plugin-page__body :global(table td) {
      padding: 8px 10px;
      font-size: 12px;
    }
  }

  /* ─── Shared section headers for stats / pipeline / gallery ─── */
  .plugin-section__head {
    margin: 0 0 18px;
  }
  .plugin-section__kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: var(--muted);
    margin: 0 0 4px;
  }
  .plugin-section__title {
    font-family: 'VT323', 'Russo One', monospace;
    font-size: clamp(24px, 3.4vw, 30px);
    color: var(--accent-2);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0;
    text-shadow: 0 0 12px color-mix(in oklab, var(--accent-2) 40%, transparent);
  }

  /* ─── Stats strip ─── */
  .plugin-stats { margin: 8px 0 56px; }
  .plugin-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  @media (max-width: 900px) { .plugin-stats__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .plugin-stats__grid { grid-template-columns: 1fr; } }
  .stat-card {
    padding: 16px 18px;
    background: color-mix(in oklab, var(--surface) 94%, black);
    border: 1px solid color-mix(in oklab, var(--accent) 25%, var(--grid));
    border-radius: 6px;
    box-shadow: inset 0 0 20px color-mix(in oklab, var(--accent) 5%, transparent);
  }
  .stat-card__label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--muted);
    margin: 0 0 8px;
    letter-spacing: 0.05em;
  }
  .stat-card__value {
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 30px;
    color: var(--ink);
    margin: 0;
    line-height: 1;
    text-shadow: var(--glow-sm);
  }
  .stat-card__delta {
    margin: 6px 0 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--accent-3);
    letter-spacing: 0.04em;
  }

  /* ─── Pipeline steps ─── */
  .plugin-pipeline { margin: 0 0 56px; }
  .plugin-pipeline__list {
    list-style: none;
    counter-reset: pipeline;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  @media (max-width: 900px) { .plugin-pipeline__list { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .plugin-pipeline__list { grid-template-columns: 1fr; } }
  .pipeline-step {
    padding: 16px 18px;
    background: color-mix(in oklab, var(--surface) 94%, black);
    border: 1px solid var(--border);
    border-left: 2px solid color-mix(in oklab, var(--accent) 60%, transparent);
    border-radius: 6px;
  }
  .pipeline-step__n {
    display: inline-block;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.14em;
    margin-bottom: 6px;
  }
  .pipeline-step__title {
    font-family: 'VT323', 'Russo One', monospace;
    font-size: 22px;
    color: var(--accent-2);
    text-transform: uppercase;
    margin: 0 0 6px;
    letter-spacing: 0.02em;
  }
  .pipeline-step__text {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ─── Gallery ─── */
  .plugin-gallery { margin: 48px 0 0; }
  .plugin-gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
  }
  .gallery-shot {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }
  .gallery-shot:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--accent) 55%, var(--border));
    box-shadow: var(--glow-md);
  }
  .gallery-shot img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    cursor: zoom-in;
    border: 0;
    border-radius: 0;
    margin: 0;
  }
  /* Override the generic .plugin-page__body img styles for gallery. */
  .plugin-page__body :global(.gallery-shot img) {
    max-width: 100%;
    margin: 0;
    border: 0;
    border-radius: 0;
  }
  .gallery-shot figcaption {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 8px 12px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--muted);
    border-top: 1px dashed var(--border);
  }
  .gallery-shot__n {
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
  }
</style>
