---
import Base from '~/layouts/Base.astro';
import { loadAllManifests, sortByUpdated, pick } from '~/lib/github/manifest';

const manifests = sortByUpdated(await loadAllManifests());
---

<Base title="Плагины // CRAFTCODE" description="Каталог плагинов CRAFTCODE." bodyClass="is-plugins">
  <section class="plugins-head">
    <p class="plugins-kicker" data-i18n="plugins.kicker">// plugin registry</p>
    <h1 class="plugins-title" data-i18n="plugins.title">Плагины</h1>
    <p class="plugins-sub" data-i18n="plugins.sub">Инструменты для Unreal Engine. Данные подтягиваются из GitHub при сборке.</p>
  </section>

  <section class="plugins-grid-section">
    <ul class="plugins-grid">
      {manifests.map((m) => (
        <li
          class="plugin-card neon-frame"
          style={m.accent ? `--accent: ${m.accent}` : undefined}
          data-name-en={pick(m.name, 'en')}
          data-name-ru={pick(m.name, 'ru')}
          data-desc-en={pick(m.description, 'en')}
          data-desc-ru={pick(m.description, 'ru')}
        >
          <a href={`/plugins/${m.slug}/`} class="plugin-card__link">
            {m.image && (
              <div class="plugin-card__thumb">
                <img
                  src={m.image}
                  alt={pick(m.name, 'ru')}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="plugin-card__body">
              <header>
                <span class="plugin-card__kicker">/{m.slug}</span>
                <span class="plugin-card__ver">v{m.version}</span>
              </header>
              <h2 class="plugin-card__name" data-loc="name">{pick(m.name, 'ru')}</h2>
              <p class="plugin-card__desc" data-loc="desc">{pick(m.description, 'ru')}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<script>
  import { onLangChange, getLang } from '~/i18n/i18n';
  const swap = (lang: 'en' | 'ru') => {
    document.querySelectorAll<HTMLElement>('.plugin-card').forEach((card) => {
      const n = card.querySelector<HTMLElement>('[data-loc="name"]');
      const d = card.querySelector<HTMLElement>('[data-loc="desc"]');
      const nv = card.dataset[`name${lang === 'ru' ? 'Ru' : 'En'}`];
      const dv = card.dataset[`desc${lang === 'ru' ? 'Ru' : 'En'}`];
      if (n && nv) n.textContent = nv;
      if (d && dv) d.textContent = dv;
    });
  };
  swap(getLang());
  onLangChange(swap);
</script>

<style>
  .plugins-head {
    max-width: 1080px;
    margin: 32px auto 20px;
    padding: 0 16px;
  }
  .plugins-kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--muted);
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .plugins-title {
    font-family: 'Press Start 2P', 'IBM Plex Mono', monospace;
    font-size: clamp(22px, 4vw, 34px);
    text-shadow: 3px 3px 0 var(--accent-2), 6px 6px 0 var(--accent);
    margin: 0 0 10px;
  }
  .plugins-sub { color: var(--muted); max-width: 60ch; }

  .plugins-grid-section { max-width: 1080px; margin: 0 auto; padding: 0 16px; }
  .plugins-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .plugin-card { padding: 0; overflow: hidden; transition: box-shadow 140ms ease, transform 140ms ease; }
  .plugin-card:hover { transform: translateY(-2px); box-shadow: var(--glow-lg); }
  .plugin-card__link {
    display: block;
    color: var(--ink);
    text-decoration: none;
  }
  .plugin-card__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--code-bg);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, var(--border));
  }
  .plugin-card__thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }
  .plugin-card:hover .plugin-card__thumb img { transform: scale(1.04); }
  .plugin-card__body { padding: 16px 18px 18px; }
  .plugin-card__body header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
  }
  .plugin-card__kicker { color: var(--muted); }
  .plugin-card__ver { color: var(--accent); text-shadow: var(--glow-sm); }
  .plugin-card__name {
    font-family: 'VT323', 'Roboto Mono', monospace;
    font-size: 26px;
    text-transform: uppercase;
    margin: 8px 0 6px;
    color: var(--accent-2);
  }
  .plugin-card__desc { color: var(--muted); line-height: 1.5; margin: 0; }
</style>
